{% extends 'base.html.twig' %}

{% block title %}
	Pedibus Jambus
{% endblock %}

{% block body %}

	<section id="upper-section"
		class="flex flex-col items-center border-2 border-green-300 rounded-md w-fit justify-center mx-auto m-4 p-4 bg-white"
	>
		<div class="flex flex-col md:flex-row text-center">
			<p class="text-3xl">
				Association de randonnée pédestre
			</p>
			<p class="text-3xl">
				-
			</p>
			<p class="text-3xl">
				77380 Combs-la-Ville
			</p>
		</div>
		<h1 class="text-3xl text-red-500 font-bold text-left">Mieux connaître notre association</h1>

		<div class="flex flex-col">
			<p class="text-xl w-lg">
				Pedibus Jambus est une association régie par la loi du 1er juillet 1901.
				Elle a pour objet la pratique et la promotion de la randonnée pédestre en tant qu'activité sportive et
				culturelle de plein air.
			</p>

			<div class="flex flex-col lg:flex-row">
				<div class="flex flex-col">
					<span class="text-xl w-lg p-4 text-blue-500 font-bold">
						« Un jour de sentier, huit jours de santé ».
					</span>
					<p class="text-xl w-lg">
						Aujourd'hui, les preuves scientifiques de cette affirmation s'accumulent. Si vous aimez la randonnée,
						la faune, la flore, notre club de randonnée pédestre "Pedibus Jambus" et ses animateurs vous feront
						découvrir les forêts et les sites de l'Île de France ainsi que des circuits originaux sur Paris ou la
						banlieue. Contrairement au sport de compétition ou de haut niveau qui aggrave le stress et l'anxiété,
						une activité physique modérée comme la randonnée renforce l'estime de soi, redonne éventuellement
						confiance et permet une meilleure intégration dans la vie sociale, d'où une meilleure qualité de la
						vie. La bonne humeur règne chez
						<span class="text-xl w-lg text-green-500 font-semibold">"Pedibus Jambus"</span>
						et l'imagination de nos animateurs pour nous concocter de belles randonnées n'est plus à démontrer. Amis
						visiteurs, nous espérons que ce site répondra à vos attentes.
					</p>
				</div>
				<img src="{{ asset('img/flower-main.jpg') }}" alt="Image d'accueil" class="h-[32pc] w-lg" />
			</div>
			<div class="flex flex-col gap-y-8 justify-center items-center">
				<p class="text-xl w-lg">
					A bientôt sur les chemins.
				</p>

				<p class="text-xl w-lg">
					l'équipe de Pedibus Jambus
				</p>
			</div>
		</div>
	</section>

	<section id="lower-section" class="flex flex-col items-center border-2 border-green-300 rounded-md w-fit justify-center mx-auto m-4 p-4 bg-white">
		<h2 class="text-2xl font-bold text-gray-800 mb-6">Nos plus récentes sorties :</h2>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
			{# Récupérer les 3 derniers albums depuis la base de données #}
			{% for album in albums|slice(0, 3) %}
			<div class="bg-gray-50 rounded-lg shadow-sm overflow-hidden border border-gray-200 hover:shadow-md transition-shadow duration-300">
				{# Titre et description de l'album #}
				<div class="p-4">
					<h3 class="text-xl font-semibold text-gray-800 mb-2">{{ album.title }}</h3>
					<p class="text-gray-600 mb-3">
						{% if album.description %}
							{{ album.description|slice(0, 100) }}{% if album.description|length > 100 %}...{% endif %}
						{% else %}
							{# Placeholder si pas de description #}
							**Nos randos de septembre et début octobre :**
							**PLACEHOLDER DESCRIPTION**
						{% endif %}
					</p>
					<div class="flex justify-between text-sm text-gray-500">
						<span>{{ album.photos|length }} photo(s)</span>
						<span>{{ album.createdAt|date('d/m/Y') }}</span>
					</div>
				</div>
				
				{# Section des photos (3 premières) #}
				<div class="p-4 bg-white border-t border-gray-100">
					<h4 class="text-sm font-medium text-gray-700 mb-3">Photos récentes :</h4>
					<div class="grid grid-cols-3 gap-2">
						{% for photo in album.photos|slice(0, 3) %}
							<div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
								{% if photo.imageName %}
									<img 
										src="{{ asset('uploads/photos/' ~ photo.imageName) }}" 
										alt="{{ photo.title ? photo.title : 'Photo ' ~ loop.index }}" 
										class="w-full h-full object-cover hover:scale-110 transition-transform duration-300"
										title="{{ photo.title ? photo.title : '' }}"
									>
								{% else %}
									<div class="w-full h-full flex items-center justify-center bg-gray-200">
										<svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
										</svg>
									</div>
								{% endif %}
							</div>
						{% else %}
							{# Si pas de photos, afficher des placeholders #}
							{% for i in 1..3 %}
								<div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
									<div class="w-full h-full flex items-center justify-center bg-gray-200">
										<svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
										</svg>
									</div>
								</div>
							{% endfor %}
						{% endfor %}
					</div>
					
					{# Bouton pour voir toutes les photos #}
					{% if album.photos|length > 0 %}
						<div class="mt-3 text-center">
							<a href="{{ path('album_show', {'id': album.id}) }}" class="inline-block text-sm text-blue-600 hover:text-blue-800 font-medium">
								Voir toutes les photos ({{ album.photos|length }})
							</a>
						</div>
					{% endif %}
				</div>
				
				{# Ligne de séparation et lien vers l'album #}
				<div class="px-4 py-3 bg-gray-50 border-t border-gray-200">
					<a href="{{ path('album_show', {'id': album.id}) }}" 
						class="block w-full text-center bg-green-500 hover:bg-green-600 text-white py-2 px-4 rounded-md font-medium transition-colors duration-300">
						Voir cet album
					</a>
				</div>
			</div>
			{% else %}
				{# Si pas d'albums #}
				<div class="col-span-3 text-center py-8">
					<svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
					</svg>
					<p class="text-gray-500">Aucun album disponible pour le moment.</p>
				</div>
			{% endfor %}
		</div>
		
		{# Lien vers tous les albums #}
		<div class="mt-8 text-center">
			<a href="{{ path('album_index') }}" class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-medium py-3 px-6 rounded-lg transition-colors duration-300">
				Voir tous nos albums de randonnées
			</a>
		</div>
	</section>
{% endblock %}
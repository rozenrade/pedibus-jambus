{% extends 'base.html.twig' %}

{% block title %}Pedibus Jambus - Connexion{% endblock %}

{% block body %}
    {# Section principale avec image de fond #}
    <section class="min-h-screen flex items-center justify-center p-4 bg-gradient-to-br from-blue-50 to-green-50">
        {# Conteneur de la carte #}
        <div class="w-full max-w-lg bg-white rounded-2xl shadow-2xl overflow-hidden">
            
            {# En-tête avec image décorative #}
            <div class="bg-gradient-to-r from-blue-500 to-green-500 p-8 text-center relative">
                <div class="absolute top-4 left-4">
                    <a href="/" class="text-white hover:text-blue-100 transition-colors">
                        <i class="fas fa-arrow-left text-xl"></i>
                    </a>
                </div>
                <div class="flex flex-col items-center">
                    <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mb-4 shadow-lg">
                        <i class="fas fa-sign-in-alt text-3xl text-blue-500"></i>
                    </div>
                    <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">Bienvenue de retour</h1>
                    <p class="text-blue-500 text-lg">Accédez à votre espace personnel</p>
                </div>
            </div>

            {# Contenu du formulaire #}
            <div class="p-8 md:p-10">
                {# Messages d'erreur #}
                {% if error %}
                    <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 rounded-r">
                        <div class="flex items-center">
                            <div class="flex-shrink-0">
                                <i class="fas fa-exclamation-circle text-red-500"></i>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-red-700">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Message de succès #}
                {% for message in app.flashes('success') %}
                    <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-r">
                        <div class="flex items-center">
                            <div class="flex-shrink-0">
                                <i class="fas fa-check-circle text-green-500"></i>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-green-700">{{ message }}</p>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                {# Intro #}
                <div class="mb-8 text-center">
                    <p class="text-gray-600">
                        Connectez-vous pour accéder à votre compte et profiter de toutes les fonctionnalités.
                    </p>
                </div>

                <form method="post" class="space-y-6" novalidate>
                    
                    {# Champ Email #}
                    <div class="space-y-2">
                        <label for="inputEmail" class="block text-sm font-medium text-gray-700">
                            <i class="fas fa-envelope mr-2 text-blue-500"></i>Adresse Email
                        </label>
                        <div class="relative">
                            <input type="email" 
                                   value="{{ last_username }}" 
                                   name="email" 
                                   id="inputEmail" 
                                   class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition duration-200 ease-in-out placeholder-gray-400"
                                   autocomplete="email" 
                                   required 
                                   autofocus 
                                   placeholder="exemple@email.com">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-at text-gray-400"></i>
                            </div>
                        </div>
                    </div>

                    {# Champ Mot de passe #}
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <label for="inputPassword" class="block text-sm font-medium text-gray-700">
                                <i class="fas fa-lock mr-2 text-blue-500"></i>Mot de passe
                            </label>
                            <a href="#" class="text-sm text-blue-600 hover:text-blue-800 transition duration-200">
                                <i class="fas fa-question-circle mr-1"></i>Mot de passe oublié ?
                            </a>
                        </div>
                        <div class="relative">
                            <input type="password" 
                                   name="password" 
                                   id="inputPassword" 
                                   class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition duration-200 ease-in-out placeholder-gray-400"
                                   autocomplete="current-password" 
                                   required 
                                   placeholder="Votre mot de passe">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-key text-gray-400"></i>
                            </div>
                            <button type="button" 
                                    class="absolute inset-y-0 right-0 pr-3 flex items-center"
                                    onclick="togglePasswordVisibility()">
                                <i id="password-toggle" class="fas fa-eye text-gray-400 hover:text-gray-600 cursor-pointer"></i>
                            </button>
                        </div>
                    </div>

                    {# Token CSRF #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    {# Options #}
                    <div class="space-y-4">
                        {# Case à cocher - Se souvenir de moi #}
                        <div class="flex items-start">
                            <div class="flex items-center h-5">
                                <input type="checkbox" 
                                       name="_remember_me" 
                                       id="remember_me"
                                       class="h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:ring-2">
                            </div>
                            <div class="ml-3">
                                <label for="remember_me" class="text-sm text-gray-700">
                                    Se souvenir de moi sur cet appareil
                                </label>
                            </div>
                        </div>

                        {# Information de sécurité #}
                        <div class="p-3 bg-blue-50 rounded-xl border border-blue-100">
                            <div class="flex items-start">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-shield-alt text-blue-500 mt-1"></i>
                                </div>
                                <div class="ml-3">
                                    <p class="text-xs text-blue-600">
                                        Pour votre sécurité, veuillez vous déconnecter si vous utilisez un ordinateur public.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Bouton de connexion #}
                    <div class="pt-4">
                        <button type="submit" 
                                class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-xl shadow-lg text-lg font-semibold text-black bg-gradient-to-r from-blue-500 to-green-500 hover:from-blue-600 hover:to-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-300 transform hover:-translate-y-1">
                            <i class="fas fa-sign-in-alt mr-3"></i>
                            Se connecter
                        </button>
                    </div>

                </form>

                {# Séparateur #}
                <div class="relative my-8">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-300"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="px-4 bg-white text-gray-500">Nouveau chez nous ?</span>
                    </div>
                </div>

                {# Lien d'inscription #}
                <div class="text-center">
                    <a href="{{ path('app_register') }}" 
                       class="inline-flex items-center px-6 py-3 border-2 border-green-500 rounded-xl text-green-600 font-medium hover:bg-green-50 transition duration-200 ease-in-out">
                        <i class="fas fa-user-plus mr-3"></i>
                        Créer un nouveau compte
                    </a>
                </div>

                {# Retour à l'accueil #}
                <div class="mt-8 text-center">
                    <a href="/" 
                       class="inline-flex items-center text-gray-600 hover:text-gray-800 transition duration-200">
                        <i class="fas fa-home mr-2"></i>
                        Retour à l'accueil
                    </a>
                </div>
            </div>

            {# Pied de page #}
            <div class="bg-gray-50 px-8 py-4 border-t border-gray-200">
                <div class="text-center text-sm text-gray-500">
                    <p>© 2024 Pedibus Jambus. Tous droits réservés.</p>
                    <p class="mt-1">
                        <a href="#" class="text-blue-600 hover:text-blue-800">
                            <i class="fas fa-question-circle mr-1"></i>Besoin d'aide ?
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </section>

    {# Script pour afficher/masquer le mot de passe #}
    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('inputPassword');
            const toggleIcon = document.getElementById('password-toggle');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }
        
        // Focus sur le champ email si erreur
        document.addEventListener('DOMContentLoaded', function() {
            {% if error %}
                document.getElementById('inputEmail').focus();
            {% endif %}
        });
    </script>
{% endblock %}
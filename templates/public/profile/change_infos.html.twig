{% extends 'base.html.twig' %}

{% block title %}
    Modifier mes informations personnelles - Pedibus Jambus
{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-8">

            {# FORMULAIRE INFORMATIONS #}
            <div class="backdrop-blur-md bg-black/40 border border-white/10 rounded-2xl shadow-2xl p-8 text-white">

                <h1 class="text-3xl font-semibold mb-8 text-center">
                    Mes informations
                </h1>

                {{ form_start(userForm, {'attr': {'enctype': 'multipart/form-data', 'class': 'space-y-6'}}) }}

                <div class="space-y-2">
                    <p class="text-sm uppercase tracking-wide text-gray-300">
                        Adresse e-mail
                    </p>

                    <div class="text-black">
                        {{ form_row(userForm.email) }}
                    </div>
                </div>

                <div class="space-y-2">
                    <p class="text-sm uppercase tracking-wide text-gray-300">
                        Pseudonyme
                    </p>

                    <p class="text-sm text-gray-400">
                        Entre 3 et 16 caractères, unique pour chaque utilisateur.
                    </p>

                    <div class="text-black">
                        {{ form_row(userForm.nickname) }}
                    </div>
                </div>

                <div class="space-y-2">
                    <p class="text-sm uppercase tracking-wide text-gray-300">
                        Photo de profil
                    </p>

                    <div class="text-white">
                        {{ form_row(userForm.avatarFile) }}
                    </div>

                    {# Aperçu nouvelle image #}
                    <img id="avatar-preview"
                        src="#"
                        alt="Aperçu"
                        class="mt-3 max-h-40 rounded-xl hidden" />

                    {# Avatar actuel #}
                    {% if app.user.avatarName %}
                        <p class="mt-2 text-sm text-gray-400">
                            Image actuelle :
                        </p>

                        <img src="{{ vich_uploader_asset(app.user, 'avatarFile') }}"
                            alt="Avatar actuel"
                            class="mt-1 max-h-40 rounded-xl">
                        {% endif %}
                    </div>

                    <div class="space-y-2">
                        <p class="text-sm uppercase tracking-wide text-gray-300">
                            Confirmation du mot de passe
                        </p>

                        <div class="text-black">
                            {{ form_row(userForm.password) }}
                        </div>
                    </div>

                    <button class="w-full py-3 rounded-xl bg-white/10 hover:bg-white/20 transition border border-white/20 text-white font-medium">
                        Modifier mes informations
                    </button>

                    {{ form_end(userForm) }}

                </div>

                {# FORMULAIRE MOT DE PASSE #}
                <div class="backdrop-blur-md bg-black/40 border border-white/10 rounded-2xl shadow-2xl p-8 text-white">

                    <h2 class="text-3xl font-semibold mb-8 text-center">
                        Mot de passe
                    </h2>

                    {{ form_start(passwordForm, {'attr': {'class': 'space-y-6'}}) }}

                    <div class="space-y-2">
                        <p class="text-sm uppercase tracking-wide text-gray-300">
                            Ancien mot de passe
                        </p>

                        <div class="text-black">
                            {{ form_row(passwordForm.oldPassword) }}
                        </div>
                    </div>

                    <div class="space-y-2">
                        <p class="text-sm uppercase tracking-wide text-gray-300">
                            Nouveau mot de passe
                        </p>

                        <div class="text-black">
                            {{ form_row(passwordForm.newPassword) }}
                        </div>
                    </div>

                    <div class="space-y-2">
                        <p class="text-sm uppercase tracking-wide text-gray-300">
                            Confirmation du nouveau mot de passe
                        </p>

                        <div class="text-black">
                            {{ form_row(passwordForm.confirmPassword) }}
                        </div>
                    </div>

                    <button class="w-full py-3 rounded-xl bg-white/10 hover:bg-white/20 transition border border-white/20 text-white font-medium">
                        Changer mon mot de passe
                    </button>

                    {{ form_end(passwordForm) }}
                </div>

            </div>
        </div>

        {% block javascripts %}
            {{ parent() }}
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const avatarInput = document.querySelector('#{{ userForm.avatarFile.vars.id }}');
                    const preview = document.getElementById('avatar-preview');

                    if (avatarInput) {
                        avatarInput.addEventListener('change', function() {
                            const file = this.files[0];

                            if (file) {
                                const reader = new FileReader();

                                reader.onload = function(e) {
                                    preview.src = e.target.result;
                                    preview.classList.remove('hidden');
                                };

                                reader.readAsDataURL(file);
                                } else {
                                // Si l'utilisateur réinitialise le champ
                                preview.src = '#';
                                preview.classList.add('hidden');
                            }
                        });
                    }
                });
            </script>
        {% endblock %}
    {% endblock %}
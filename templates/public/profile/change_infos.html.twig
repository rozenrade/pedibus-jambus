{% extends 'base.html.twig' %}

{% block title %}
    Modifier mes informations personnelles - Pedibus Jambus
{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-8">

            {# FORMULAIRE INFORMATIONS #}
            <div class="backdrop-blur-md bg-black/40 border border-white/10 rounded-2xl shadow-2xl p-8 text-white">

                <h1 class="text-3xl font-semibold mb-8 text-center">
                    Mes informations
                </h1>

                {{ form_start(userForm, {'attr': {'enctype': 'multipart/form-data', 'class': 'space-y-6'}}) }}

                <div class="space-y-2">
                    <p class="text-base font-semibold uppercase tracking-wide text-white">
                        Adresse e-mail
                    </p>

                    <div>
                        {{ form_row(userForm.email, {
                            'attr': {
                                'class': 'w-full rounded-xl bg-white text-black text-lg px-4 py-3 border-2 border-gray-300 focus:border-cyan-500 focus:ring-4 focus:ring-cyan-300 focus:outline-none'
                            }
                        }) }}
                    </div>
                </div>

                {# Password avec bouton afficher/masquer (Stimulus) #}
                <div class="space-y-2">
                    <p class="text-base font-semibold uppercase tracking-wide text-white">
                        Confirmation du mot de passe
                    </p>

                    <div class="relative" data-controller="password-toggle">
                        {{ form_widget(userForm.password, {
                            'attr': {
                                'class': 'w-full rounded-xl bg-white text-black text-lg px-4 py-3 pr-12 border-2 border-gray-300 focus:border-cyan-500 focus:ring-4 focus:ring-cyan-300 focus:outline-none',
                                'data-password-toggle-target': 'input'
                            }
                        }) }}

                        <button
                            type="button"
                            data-action="password-toggle#toggle"
                            data-password-toggle-target="button"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                            class="absolute inset-y-0 right-0 flex items-center px-4 text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-cyan-500 rounded-r-xl"
                        >
                            <i data-password-toggle-target="icon" class="fas fa-eye"></i>
                        </button>
                    </div>

                    {{ form_errors(userForm.password) }}
                </div>

                <button type="submit" class="w-full py-4 rounded-xl bg-cyan-600 hover:bg-cyan-700 transition border-2 border-cyan-700 text-white text-lg font-semibold focus:outline-none focus:ring-4 focus:ring-cyan-300">
                    Modifier mes informations
                </button>

                {{ form_end(userForm) }}

            </div>

            {# FORMULAIRE MOT DE PASSE #}
            <div class="backdrop-blur-md bg-black/40 border border-white/10 rounded-2xl shadow-2xl p-8 text-white">

                <h2 class="text-3xl font-semibold mb-8 text-center">
                    Mot de passe
                </h2>

                {{ form_start(passwordForm, {'attr': {'class': 'space-y-6'}}) }}

                <div class="space-y-2">
                    <p class="text-base font-semibold uppercase tracking-wide text-white">
                        Ancien mot de passe
                    </p>

                    <div class="relative" data-controller="password-toggle">
                        {{ form_widget(passwordForm.oldPassword, {
                            'attr': {
                                'class': 'w-full rounded-xl bg-white text-black text-lg px-4 py-3 pr-12 border-2 border-gray-300 focus:border-cyan-500 focus:ring-4 focus:ring-cyan-300 focus:outline-none',
                                'data-password-toggle-target': 'input'
                            }
                        }) }}

                        <button
                            type="button"
                            data-action="password-toggle#toggle"
                            data-password-toggle-target="button"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                            class="absolute inset-y-0 right-0 flex items-center px-4 text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-cyan-500 rounded-r-xl"
                        >
                            <i data-password-toggle-target="icon" class="fas fa-eye"></i>
                        </button>
                    </div>

                    {{ form_errors(passwordForm.oldPassword) }}
                </div>

                <div class="space-y-2">
                    <p class="text-base font-semibold uppercase tracking-wide text-white">
                        Nouveau mot de passe
                    </p>

                    <div class="relative" data-controller="password-toggle">
                        {{ form_widget(passwordForm.newPassword, {
                            'attr': {
                                'class': 'w-full rounded-xl bg-white text-black text-lg px-4 py-3 pr-12 border-2 border-gray-300 focus:border-cyan-500 focus:ring-4 focus:ring-cyan-300 focus:outline-none',
                                'data-password-toggle-target': 'input'
                            }
                        }) }}

                        <button
                            type="button"
                            data-action="password-toggle#toggle"
                            data-password-toggle-target="button"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                            class="absolute inset-y-0 right-0 flex items-center px-4 text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-cyan-500 rounded-r-xl"
                        >
                            <i data-password-toggle-target="icon" class="fas fa-eye"></i>
                        </button>
                    </div>

                    {{ form_errors(passwordForm.newPassword) }}
                </div>

                <div class="space-y-2">
                    <p class="text-base font-semibold uppercase tracking-wide text-white">
                        Confirmation du nouveau mot de passe
                    </p>

                    <div class="relative" data-controller="password-toggle">
                        {{ form_widget(passwordForm.confirmPassword, {
                            'attr': {
                                'class': 'w-full rounded-xl bg-white text-black text-lg px-4 py-3 pr-12 border-2 border-gray-300 focus:border-cyan-500 focus:ring-4 focus:ring-cyan-300 focus:outline-none',
                                'data-password-toggle-target': 'input'
                            }
                        }) }}

                        <button
                            type="button"
                            data-action="password-toggle#toggle"
                            data-password-toggle-target="button"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                            class="absolute inset-y-0 right-0 flex items-center px-4 text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-cyan-500 rounded-r-xl"
                        >
                            <i data-password-toggle-target="icon" class="fas fa-eye"></i>
                        </button>
                    </div>

                    {{ form_errors(passwordForm.confirmPassword) }}
                </div>

                <button type="submit" class="w-full py-4 rounded-xl bg-cyan-600 hover:bg-cyan-700 transition border-2 border-cyan-700 text-white text-lg font-semibold focus:outline-none focus:ring-4 focus:ring-cyan-300">
                    Changer mon mot de passe
                </button>

                {{ form_end(passwordForm) }}
            </div>

        </div>
    </div>
{% endblock %}

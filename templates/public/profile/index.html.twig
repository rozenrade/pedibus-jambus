{% extends 'base.html.twig' %}

{% block title %}Mon profil - Pedibus Jambus{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto mt-12 mb-16 px-4">

    {# Carte profil #}
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-md p-8">

        {# Avatar + nom #}
        <div class="flex flex-col items-center mb-8">
            {% if app.user.avatarName %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatarName) }}"
                     alt="Avatar de {{ app.user.nickname ?? app.user.email }}"
                     class="w-24 h-24 rounded-full object-cover mb-4 shadow">
            {% else %}
                <div class="w-24 h-24 rounded-full bg-cyan-100 flex items-center justify-center mb-4 shadow">
                    <i class="fa-solid fa-user text-3xl text-cyan-400"></i>
                </div>
            {% endif %}

            <h1 class="text-2xl font-bold text-gray-800">
                {{ app.user.nickname ?? app.user.email }}
            </h1>
            <p class="text-sm text-gray-500 mt-1">{{ app.user.email }}</p>
        </div>

        {# Actions #}
        <div class="flex flex-col gap-3">
            <a href="{{ path('app_profile_change_data') }}"
               class="w-full text-center bg-cyan-600 hover:bg-cyan-700 text-white font-medium py-2.5 rounded-xl transition">
                <i class="fa-solid fa-pen-to-square mr-2"></i>Modifier mes informations
            </a>

            <button onclick="document.getElementById('modal-delete').classList.remove('hidden')"
                    class="w-full text-center bg-white hover:bg-red-50 text-red-500 border border-red-200 font-medium py-2.5 rounded-xl transition">
                <i class="fa-solid fa-trash mr-2"></i>Supprimer mon compte
            </button>
        </div>
    </div>
</div>

{# Modale suppression #}
<div id="modal-delete" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 px-4">
    <div class="bg-white rounded-2xl shadow-xl p-8 w-full max-w-sm">

        <div class="flex flex-col items-center mb-6">
            <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-3">
                <i class="fa-solid fa-triangle-exclamation text-red-500 text-xl"></i>
            </div>
            <h2 class="text-lg font-bold text-gray-800" style="font-family: 'Merriweather', serif;">
                Supprimer mon compte
            </h2>
            <p class="text-sm text-gray-500 text-center mt-1">
                Cette action est irréversible. Confirmez votre mot de passe pour continuer.
            </p>
        </div>

        <form method="POST" action="{{ path('app_profile_delete_account') }}" class="flex flex-col gap-4">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-account-' ~ app.user.id) }}">

            <input type="password"
                   name="password"
                   required
                   autofocus
                   placeholder="Votre mot de passe"
                   class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-200">

            <button type="submit"
                    class="w-full bg-red-500 hover:bg-red-600 text-white font-medium py-2.5 rounded-xl transition text-sm">
                Confirmer la suppression
            </button>

            <button type="button"
                    onclick="document.getElementById('modal-delete').classList.add('hidden')"
                    class="w-full text-gray-500 hover:text-gray-700 text-sm transition">
                Annuler
            </button>
        </form>
    </div>
</div>
{% endblock %}
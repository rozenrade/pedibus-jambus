{% extends 'base.html.twig' %}

{% block title %}Mon profil - Pedibus Jambus
{% endblock %}

{% block body %}
	<h1>Mon profil</h1>

	<p>Bienvenue sur votre page de profil {{ app.user.nickname? app.user.nickname : app.user.email }} !</p>
	{% if app.user.avatarName %}
		<img src="{{ asset('uploads/avatars/' ~ app.user.avatarName) }}" alt="Avatar" class="rounded-full w-32 h-32 mb-4">
	{% else %}
		<img src="{{ asset('default.png') }}" alt="Avatar" class="rounded-full w-32 h-32 mb-4">
	{% endif %}

	<p>Cliquez ici pour modifier vos informations personnelles :
		<a href="{{ path('app_profile_change_data')}}">ici</a>.
	</p>
{% endblock %}

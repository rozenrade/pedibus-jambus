{# templates/public/hiking_program/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Programmes - PEDIBUS JAMBUS{% endblock %}

{% block body %}
<div class="min-h-screen py-12 px-4 relative">
    <!-- Overlay pour améliorer la lisibilité sur l'image de fond -->
    <div class="absolute inset-0 z-0"></div>
    
    <div class="relative z-10">
        <div class="max-w-5xl mx-auto">
            <!-- En-tête centré -->
            <div class="text-center mb-12">
                <h1 class="text-4xl font-bold text-gray-900 mb-4">Programmes de randonnée</h1>
                <p class="text-lg text-gray-700 max-w-3xl mx-auto">
                    Retrouvez tous nos programmes organisés par année. Téléchargez les PDF pour être informé des prochaines randonnées.
                </p>
            </div>
            
            {% if groupedPrograms|length > 0 %}
                <div class="space-y-10">
                    {% for year, programs in groupedPrograms %}
                        <div class="backdrop-blur-sm bg-white/70 rounded-2xl shadow-xl border border-white/30 overflow-hidden">
                            <!-- Titre de l'année avec fond dégradé -->
                            <div class="bg-gradient-to-r from-green-600/80 to-green-700/80 px-8 py-6">
                                <div class="flex items-center justify-center">
                                    <svg class="w-7 h-7 text-black mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    <h2 class="text-2xl font-bold text-black">{{ year }}</h2>
                                </div>
                            </div>
                            
                            <!-- Liste des programmes -->
                            <div class="p-2">
                                {% for program in programs %}
                                    <div class="group p-6 hover:bg-white/50 transition-all duration-300 border-b border-gray-300 last:border-b-0">
                                        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
                                            <div class="flex-1">
                                                <!-- Titre et informations -->
                                                <div class="flex items-start gap-4">
                                                    <!-- Icône PDF -->
                                                    <div class="flex-shrink-0">
                                                        <div class="p-2 bg-red-100/80 rounded-lg group-hover:bg-red-100 transition-colors">
                                                            <svg class="w-6 h-6 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                                                                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                                                            </svg>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="flex-1 min-w-0">
                                                        <h3 class="text-xl font-semibold text-gray-900 mb-2">
                                                            {{ program.title }}
                                                        </h3>
                                                        
                                                        <!-- Badges -->
                                                        <div class="flex flex-wrap gap-2 mb-3">
                                                            {% if program.quarter %}
                                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100/80 text-blue-800 backdrop-blur-sm">
                                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                                                    </svg>
                                                                    {{ program.quarter }}er trimestre
                                                                </span>
                                                            {% else %}
                                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100/80 text-green-800 backdrop-blur-sm">
                                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                                    </svg>
                                                                    Sorties Grandes Évasions
                                                                </span>
                                                            {% endif %}
                                                            
                                                            {% if program.updateAt %}
                                                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100/80 text-gray-800 backdrop-blur-sm">
                                                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                                    </svg>
                                                                    {{ program.updateAt|date('d/m/Y') }}
                                                                </span>
                                                            {% endif %}
                                                        </div>
                                                        
                                                        <!-- Description -->
                                                        {% if program.description %}
                                                            <p class="text-gray-700">{{ program.description }}</p>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Bouton télécharger -->
                                            {% if program.pdfName %}
                                                <div class="flex-shrink-0">
                                                    <a href="{{ program.pdfUrl }}" 
                                                       target="_blank" 
                                                       class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-red-600 to-red-700 text-black font-medium rounded-xl hover:from-red-700 hover:to-red-800 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1">
                                                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                                        </svg>
                                                        Voir
                                                    </a>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
                
                <!-- Information -->
                <div class="mt-12 p-8 bg-white/80 backdrop-blur-sm rounded-2xl border border-white/30 shadow-lg">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 mr-4">
                            <div class="p-3 bg-green-100/80 rounded-xl">
                                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Que contiennent ces programmes ?</h3>
                            <ul class="text-gray-700 space-y-2">
                                <li class="flex items-start">
                                    <span class="text-green-600 mr-2">•</span>
                                    Les kilométrages des randonnées
                                </li>
                                <li class="flex items-start">
                                    <span class="text-green-600 mr-2">•</span>
                                    La difficulté de chacune des randonnées
                                </li>
                                <li class="flex items-start">
                                    <span class="text-green-600 mr-2">•</span>
                                    Les différents animateurs vous accompagnant
                                </li>
                                <li class="flex items-start">
                                    <span class="text-green-600 mr-2">•</span>
                                    Leur durées ainsi que l'heure de rendez-vous
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Message si aucun programme -->
                <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-white/30 p-12 text-center">
                    <div class="max-w-md mx-auto">
                        <div class="p-4 bg-gray-100/80 rounded-full w-20 h-20 mx-auto mb-6 flex items-center justify-center">
                            <svg class="w-10 h-10 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-4">Aucun programme disponible</h3>
                        <p class="text-gray-700 mb-8">
                            Les programmes de randonnée seront bientôt publiés ici.
                            Revenez régulièrement pour découvrir nos nouvelles activités.
                        </p>
                        <a href="{{ path('app_home') }}" class="inline-flex items-center px-8 py-3 bg-gradient-to-r from-green-600 to-green-700 text-white font-medium rounded-xl hover:from-green-700 hover:to-green-800 transition-all duration-300 shadow-lg">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                            </svg>
                            Retour à l'accueil
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
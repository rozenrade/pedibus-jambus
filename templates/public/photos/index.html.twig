{# templates/base_public.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Galerie Photos{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <style>
        .album-card {
            transition: transform 0.3s ease;
        }
        .album-card:hover {
            transform: translateY(-5px);
        }
        .photo-thumbnail {
            height: 200px;
            object-fit: cover;
            width: 100%;
        }
        .photo-card {
            transition: all 0.3s ease;
        }
        .photo-card:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .tag-badge {
            cursor: pointer;
            transition: opacity 0.3s;
        }
        .tag-badge:hover {
            opacity: 0.8;
        }
        .lightbox-img {
            max-height: 80vh;
            max-width: 100%;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('public_albums') }}">
                <i class="bi bi-camera"></i> Galerie Photos
            </a>
            
            <div class="d-flex">
                <form class="d-flex" action="{{ path('public_search') }}" method="get">
                    <input class="form-control me-2" type="search" name="q" placeholder="Rechercher..." 
                           value="{{ app.request.query.get('q') }}">
                    <button class="btn btn-outline-light" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">© {{ "now"|date("Y") }} Galerie Photos - Tous droits réservés</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js"></script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>
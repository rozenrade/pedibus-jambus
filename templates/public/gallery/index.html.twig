{# templates/public_albums/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Photos publiques - Pedibus Jambus{% endblock %}

{% block body %}
<!-- Section des photos publiques -->
<section class="w-full px-4 py-8 relative">
    <div class="max-w-7xl mx-auto">
        <!-- Conteneur avec fond blanc semi-transparent -->
        <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 md:p-8">
            <!-- En-tête -->
            <div class="text-center mb-10">
                <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-800 mb-4">
                    <i class="fas fa-images mr-2 text-blue-500"></i>
                    Photos des randonnées publiques
                </h1>
                <p class="text-gray-600 text-lg md:text-xl max-w-3xl mx-auto">
                    Toutes les photos de nos albums publics, triées du plus récent au plus ancien.
                </p>
                
                <!-- Statistiques -->
                <div class="mt-6 flex flex-wrap justify-center gap-4">
                    {% set totalPhotos = 0 %}
                    {% for album in albums %}
                        {% set totalPhotos = totalPhotos + album.photos|length %}
                    {% endfor %}
                    
                    <div class="bg-green-50 px-4 py-2 rounded-full flex items-center gap-2">
                        <i class="fas fa-images text-green-500"></i>
                        <span class="text-green-700 font-semibold">{{ totalPhotos }} photos</span>
                    </div>
                    
                    <div class="bg-blue-50 px-4 py-2 rounded-full flex items-center gap-2">
                        <i class="fas fa-folder-open text-blue-500"></i>
                        <span class="text-blue-700 font-semibold">{{ albums|length }} albums</span>
                    </div>
                </div>
            </div>

            {% if albums|length > 0 %}
                <!-- Toutes les photos regroupées -->
                <div class="mb-10">
                    <!-- Bouton pour afficher/masquer les filtres par album -->
                    <div class="flex justify-end mb-6">
                        <button id="toggleFilters" class="flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition-colors">
                            <i class="fas fa-filter"></i>
                            <span class="hidden md:inline">Filtrer par album</span>
                        </button>
                    </div>
                    
                    <!-- Filtres par album (cachés par défaut) -->
                    <div id="albumFilters" class="hidden mb-8 p-6 bg-gray-50 rounded-xl">
                        <h3 class="text-lg font-semibold text-gray-700 mb-4">Filtrer par album :</h3>
                        <div class="flex flex-wrap gap-3">
                            <button class="album-filter active px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-medium hover:bg-blue-700 transition" data-album="all">
                                Toutes les photos
                            </button>
                            {% for album in albums %}
                                <button class="album-filter px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition" data-album="{{ album.id }}">
                                    {{ album.title|truncate(20) }} ({{ album.photos|length }})
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                    
                    <!-- Conteneur des photos -->
                    <div class="relative">
                        {% for album in albums %}
                            {% if album.photos|length > 0 %}
                                <!-- Titre de l'album en haut à gauche -->
                                <div class="album-section mb-10" data-album-id="{{ album.id }}">
                                    <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
                                        <div class="flex-shrink-0">
                                            <div class="w-12 h-12 rounded-lg overflow-hidden">
                                                {% if album.coverImage %}
                                                    <img 
                                                        src="{{ asset('uploads/album_covers/' ~ album.coverImage) }}" 
                                                        alt="{{ album.title }}" 
                                                        class="w-full h-full object-cover"
                                                    >
                                                {% elseif album.photos|length > 0 %}
                                                    {% set firstPhoto = album.photos.first() %}
                                                    <img 
                                                        src="{{ asset('uploads/photos/' ~ firstPhoto.imageName) }}" 
                                                        alt="{{ album.title }}" 
                                                        class="w-full h-full object-cover"
                                                    >
                                                {% else %}
                                                    <div class="w-full h-full bg-gradient-to-br from-blue-100 to-purple-100 flex items-center justify-center">
                                                        <i class="fas fa-images text-gray-400 text-xl"></i>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                        
                                        <div class="flex-1">
                                            <h2 class="text-xl md:text-2xl font-bold text-gray-800">
                                                {{ album.title }}
                                            </h2>
                                            <div class="flex flex-wrap items-center gap-3 mt-2">
                                                <span class="text-sm text-gray-500">
                                                    <i class="fas fa-calendar-alt mr-1"></i>
                                                    {{ album.eventDate|date('d/m/Y') }}
                                                </span>
                                                <span class="text-sm text-gray-500">
                                                    <i class="fas fa-images mr-1"></i>
                                                    {{ album.photos|length }} photos
                                                </span>
                                                {% if album.description %}
                                                    <span class="text-sm text-gray-500">
                                                        {{ album.description|truncate(50) }}
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        
                                        <div class="hidden md:block">
                                            <span class="bg-green-100 text-green-800 text-xs font-semibold px-3 py-1 rounded-full">
                                                <i class="fas fa-globe-americas mr-1"></i>
                                                Public
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <!-- Grille de photos -->
                                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                                        {% for photo in album.photos %}
                                            <!-- Carte photo -->
                                            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 group photo-item" 
                                                 data-album-id="{{ album.id }}"
                                                 data-photo-index="{{ loop.index }}">
                                                <!-- Image -->
                                                <div class="relative overflow-hidden aspect-square">
                                                    <img 
                                                        src="{{ asset('uploads/photos/' ~ photo.imageName) }}" 
                                                        alt="{{ photo.title ? photo.title : 'Photo ' ~ loop.index }}" 
                                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                                                        loading="lazy"
                                                        onclick="openLightbox('{{ album.id }}', {{ loop.index0 }})"
                                                    >
                                                    
                                                    <!-- Overlay info -->
                                                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
                                                        <div class="p-4 w-full text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                                            {% if photo.title %}
                                                                <p class="text-sm font-medium mb-1 truncate">{{ photo.title }}</p>
                                                            {% endif %}
                                                            <p class="text-xs opacity-90">
                                                                <i class="far fa-clock mr-1"></i>
                                                                {{ photo.createdAt|date('d/m/Y') }}
                                                            </p>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Badge si la photo a des tags -->
                                                    {% if photo.tags|length > 0 %}
                                                        <div class="absolute top-3 right-3">
                                                            <span class="bg-black/70 text-white text-xs px-2 py-1 rounded-full flex items-center gap-1">
                                                                <i class="fas fa-tag text-xs"></i>
                                                                {{ photo.tags|length }}
                                                            </span>
                                                        </div>
                                                    {% endif %}
                                                    
                                                    <!-- Numéro de la photo dans l'album -->
                                                    <div class="absolute top-3 left-3">
                                                        <span class="bg-black/70 text-white text-xs font-bold px-2 py-1 rounded-full">
                                                            #{{ loop.index }}
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Métadonnées (optionnel, visible au hover) -->
                                                <div class="p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                                    {% if photo.title %}
                                                        <h3 class="font-semibold text-gray-800 mb-2 truncate">
                                                            {{ photo.title }}
                                                        </h3>
                                                    {% endif %}
                                                    
                                                    <!-- Tags -->
                                                    {% if photo.tags|length > 0 %}
                                                        <div class="mt-2">
                                                            <div class="flex flex-wrap gap-1">
                                                                {% for tag in photo.tags|slice(0, 2) %}
                                                                    <span class="inline-block bg-blue-50 text-blue-700 text-xs px-2 py-1 rounded">
                                                                        #{{ tag }}
                                                                    </span>
                                                                {% endfor %}
                                                                {% if photo.tags|length > 2 %}
                                                                    <span class="inline-block bg-gray-100 text-gray-500 text-xs px-2 py-1 rounded">
                                                                        +{{ photo.tags|length - 2 }}
                                                                    </span>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    
                    <!-- Message si aucune photo -->
                    {% set hasPhotos = false %}
                    {% for album in albums %}
                        {% if album.photos|length > 0 %}
                            {% set hasPhotos = true %}
                        {% endif %}
                    {% endfor %}
                    
                    {% if not hasPhotos %}
                        <div class="text-center py-12 md:py-16">
                            <div class="max-w-md mx-auto">
                                <div class="bg-gradient-to-br from-gray-50 to-blue-50 rounded-2xl p-8 mb-6">
                                    <i class="fas fa-image text-5xl text-gray-300 mb-4"></i>
                                    <h3 class="text-xl md:text-2xl font-bold text-gray-700 mb-3">
                                        Aucune photo disponible
                                    </h3>
                                    <p class="text-gray-500">
                                        Les photos seront ajoutées prochainement dans les albums publics.
                                    </p>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
                
                <!-- Bouton retour -->
                <div class="text-center mt-10 md:mt-12">
                    <a 
                        href="{{ path('app_home') }}" 
                        class="inline-flex items-center gap-3 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white font-semibold py-3 px-8 rounded-full transition-all duration-300 hover:shadow-lg hover:scale-105"
                    >
                        <i class="fas fa-home"></i>
                        Retour à l'accueil
                    </a>
                </div>
                
            {% else %}
                <!-- Message si aucun album public -->
                <div class="text-center py-12 md:py-16">
                    <div class="max-w-md mx-auto">
                        <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-2xl p-8 mb-6">
                            <i class="fas fa-folder-open text-5xl text-gray-300 mb-4"></i>
                            <h3 class="text-xl md:text-2xl font-bold text-gray-700 mb-3">
                                Aucun album public disponible
                            </h3>
                            <p class="text-gray-500 mb-4">
                                Les albums seront publiés ici lorsqu'ils seront marqués comme publics par l'administrateur.
                            </p>
                            <div class="h-1 w-20 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full"></div>
                        </div>
                        
                        <a 
                            href="{{ path('app_home') }}" 
                            class="inline-flex items-center gap-3 bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 px-6 rounded-full transition-all duration-300 hover:shadow-lg"
                        >
                            <i class="fas fa-arrow-left"></i>
                            Retour à l'accueil
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</section>

<!-- Lightbox améliorée -->
<div id="lightbox" class="hidden fixed inset-0 z-50 bg-black bg-opacity-95">
    <button id="lightbox-close" class="absolute top-4 right-4 md:top-6 md:right-6 text-white text-3xl z-50 bg-black bg-opacity-50 rounded-full w-10 h-10 md:w-12 md:h-12 flex items-center justify-center hover:bg-opacity-70 transition-colors">
        &times;
    </button>
    
    <button id="lightbox-prev" class="absolute left-2 md:left-4 top-1/2 transform -translate-y-1/2 text-white text-3xl md:text-4xl z-50 bg-black bg-opacity-50 rounded-full w-10 h-10 md:w-12 md:h-12 flex items-center justify-center hover:bg-opacity-70 transition-colors">
        ‹
    </button>
    
    <button id="lightbox-next" class="absolute right-2 md:right-4 top-1/2 transform -translate-y-1/2 text-white text-3xl md:text-4xl z-50 bg-black bg-opacity-50 rounded-full w-10 h-10 md:w-12 md:h-12 flex items-center justify-center hover:bg-opacity-70 transition-colors">
        ›
    </button>

    <div class="relative z-40 flex flex-col items-center justify-center h-full p-2 md:p-4">
        <!-- Titre de l'album -->
        <div id="lightbox-album-title" class="text-white text-center mb-4 max-w-2xl px-4">
            <h2 class="text-lg md:text-xl font-bold"></h2>
        </div>
        
        <!-- Image -->
        <img id="lightbox-img" class="max-w-full max-h-[60vh] md:max-h-[70vh] object-contain rounded-lg" src="" alt="">
        
        <!-- Info photo -->
        <div id="lightbox-info" class="mt-4 text-white text-center max-w-2xl px-4">
            <h3 id="lightbox-photo-title" class="text-lg font-semibold mb-2"></h3>
            <p id="lightbox-photo-description" class="text-sm opacity-90 mb-2"></p>
            <div id="lightbox-photo-tags" class="flex flex-wrap justify-center gap-2 mb-2"></div>
            <div class="text-sm opacity-80 flex items-center justify-center gap-4">
                <span id="lightbox-photo-date"></span>
                <span id="lightbox-photo-count" class="font-medium"></span>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Variables lightbox
            let currentAlbumId = null;
            let currentPhotoIndex = 0;
            let allPhotos = [];
            
            // Récupérer toutes les données des photos
            const photoItems = document.querySelectorAll('.photo-item');
            photoItems.forEach(item => {
                const albumId = item.dataset.albumId;
                const photoIndex = parseInt(item.dataset.photoIndex) - 1;
                const img = item.querySelector('img');
                const title = item.querySelector('h3');
                const tags = item.querySelectorAll('.bg-blue-50.text-blue-700');
                
                allPhotos.push({
                    albumId: albumId,
                    index: photoIndex,
                    src: img.src,
                    alt: img.alt,
                    title: title ? title.textContent.trim() : '',
                    tags: Array.from(tags).map(tag => tag.textContent.trim())
                });
            });
            
            // Trier les photos par date (si nécessaire)
            // allPhotos.sort((a, b) => b.index - a.index);
            
            // Fonction pour ouvrir lightbox
            function openLightbox(albumId, photoIndex) {
                currentAlbumId = albumId;
                currentPhotoIndex = photoIndex;
                
                // Trouver l'album
                const albumSection = document.querySelector(`.album-section[data-album-id="${albumId}"]`);
                const albumTitle = albumSection ? albumSection.querySelector('h2').textContent.trim() : '';
                
                // Récupérer toutes les photos de cet album
                const albumPhotos = allPhotos.filter(p => p.albumId === albumId);
                const currentPhoto = albumPhotos[photoIndex];
                
                // Mettre à jour la lightbox
                const img = document.getElementById('lightbox-img');
                const albumTitleEl = document.getElementById('lightbox-album-title').querySelector('h2');
                const photoTitle = document.getElementById('lightbox-photo-title');
                const photoDesc = document.getElementById('lightbox-photo-description');
                const photoTags = document.getElementById('lightbox-photo-tags');
                const photoDate = document.getElementById('lightbox-photo-date');
                const photoCount = document.getElementById('lightbox-photo-count');
                
                img.src = currentPhoto.src;
                img.alt = currentPhoto.alt;
                albumTitleEl.textContent = albumTitle;
                photoTitle.textContent = currentPhoto.title || 'Photo sans titre';
                photoDesc.textContent = currentPhoto.description || '';
                photoDate.textContent = 'Ajoutée récemment';
                photoCount.textContent = `${photoIndex + 1} / ${albumPhotos.length}`;
                
                // Mettre à jour les tags
                photoTags.innerHTML = '';
                if (currentPhoto.tags && currentPhoto.tags.length > 0) {
                    currentPhoto.tags.forEach(tag => {
                        const tagSpan = document.createElement('span');
                        tagSpan.className = 'inline-block bg-white/20 text-white text-xs px-2 py-1 rounded';
                        tagSpan.textContent = tag;
                        photoTags.appendChild(tagSpan);
                    });
                }
                
                // Afficher la lightbox
                document.getElementById('lightbox').classList.remove('hidden');
                document.body.style.overflow = 'hidden';
                
                // Gérer la navigation
                document.getElementById('lightbox-prev').style.display = photoIndex > 0 ? 'flex' : 'none';
                document.getElementById('lightbox-next').style.display = photoIndex < albumPhotos.length - 1 ? 'flex' : 'none';
            }
            
            // Navigation lightbox
            function lightboxPrev() {
                if (currentAlbumId && currentPhotoIndex > 0) {
                    openLightbox(currentAlbumId, currentPhotoIndex - 1);
                }
            }
            
            function lightboxNext() {
                const albumPhotos = allPhotos.filter(p => p.albumId === currentAlbumId);
                if (currentAlbumId && currentPhotoIndex < albumPhotos.length - 1) {
                    openLightbox(currentAlbumId, currentPhotoIndex + 1);
                }
            }
            
            // Fermer lightbox
            function closeLightbox() {
                document.getElementById('lightbox').classList.add('hidden');
                document.body.style.overflow = '';
            }
            
            // Exposer les fonctions globalement
            window.openLightbox = openLightbox;
            window.closeLightbox = closeLightbox;
            window.lightboxPrev = lightboxPrev;
            window.lightboxNext = lightboxNext;
            
            // Événements lightbox
            document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
            document.getElementById('lightbox-prev').addEventListener('click', lightboxPrev);
            document.getElementById('lightbox-next').addEventListener('click', lightboxNext);
            
            // Navigation clavier
            document.addEventListener('keydown', (e) => {
                if (!document.getElementById('lightbox').classList.contains('hidden')) {
                    switch(e.key) {
                        case 'Escape':
                            closeLightbox();
                            break;
                        case 'ArrowLeft':
                            lightboxPrev();
                            break;
                        case 'ArrowRight':
                            lightboxNext();
                            break;
                    }
                }
            });
            
            // Fermer en cliquant sur l'overlay
            document.getElementById('lightbox').addEventListener('click', function(e) {
                if (e.target === this) {
                    closeLightbox();
                }
            });
            
            // Filtres par album
            const toggleFiltersBtn = document.getElementById('toggleFilters');
            const albumFilters = document.getElementById('albumFilters');
            const albumFilterBtns = document.querySelectorAll('.album-filter');
            
            if (toggleFiltersBtn) {
                toggleFiltersBtn.addEventListener('click', () => {
                    albumFilters.classList.toggle('hidden');
                });
            }
            
            albumFilterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const albumId = this.dataset.album;
                    
                    // Mettre à jour les boutons actifs
                    albumFilterBtns.forEach(b => {
                        b.classList.remove('active', 'bg-blue-600', 'text-white');
                        b.classList.add('bg-gray-100', 'text-gray-700');
                    });
                    this.classList.remove('bg-gray-100', 'text-gray-700');
                    this.classList.add('active', 'bg-blue-600', 'text-white');
                    
                    // Filtrer les albums
                    const albumSections = document.querySelectorAll('.album-section');
                    if (albumId === 'all') {
                        albumSections.forEach(section => {
                            section.style.display = 'block';
                        });
                    } else {
                        albumSections.forEach(section => {
                            if (section.dataset.albumId === albumId) {
                                section.style.display = 'block';
                            } else {
                                section.style.display = 'none';
                            }
                        });
                    }
                });
            });
            
            // Animation au scroll
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });
            
            const albumSections = document.querySelectorAll('.album-section');
            albumSections.forEach(section => {
                section.style.opacity = '0';
                section.style.transform = 'translateY(20px)';
                section.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                observer.observe(section);
            });
        });
    </script>
{% endblock %}
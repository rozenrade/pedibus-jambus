{% block body %}
<!-- Section des photos publiques -->
<section class="w-full px-4 py-8 relative">
    <div class="max-w-7xl mx-auto">
        <!-- Conteneur avec fond blanc semi-transparent -->
        <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 md:p-8">
            <!-- En-tête -->
            <div class="text-center mb-10">
                <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-800 mb-4">
                    <i class="fas fa-images mr-2 text-blue-500"></i>
                    Photos des randonnées publiques
                </h1>
                <p class="text-gray-600 text-lg md:text-xl max-w-3xl mx-auto">
                    Toutes les photos de nos albums publics, triées du plus récent au plus ancien.
                </p>
                
                <!-- Statistiques -->
                <div class="mt-6 flex flex-wrap justify-center gap-4">
                    {% set totalPhotos = 0 %}
                    {% for album in albums %}
                        {% set totalPhotos = totalPhotos + album.photos|length %}
                    {% endfor %}
                    
                    <div class="bg-green-50 px-4 py-2 rounded-full flex items-center gap-2">
                        <i class="fas fa-images text-green-500"></i>
                        <span class="text-green-700 font-semibold">{{ totalPhotos }} photos</span>
                    </div>
                    
                    <div class="bg-blue-50 px-4 py-2 rounded-full flex items-center gap-2">
                        <i class="fas fa-folder-open text-blue-500"></i>
                        <span class="text-blue-700 font-semibold">{{ albums|length }} albums</span>
                    </div>
                </div>
            </div>

            {% if albums|length > 0 %}
                <!-- Conteneur des albums -->
                <div class="space-y-12">
                    {% for album in albums %}
                        {% if album.photos|length > 0 %}
                            <!-- Section d'album -->
                            <div class="album-section" data-album-id="{{ album.id }}">
                                <!-- En-tête de l'album -->
                                <div class="flex items-center justify-between mb-6 pb-4 border-b border-gray-200">
                                    <div class="flex items-center gap-4">
                                        <!-- Icône de l'album -->
                                        <div class="relative">
                                            <div class="w-12 h-12 rounded-lg overflow-hidden border-2 border-white shadow">
                                                {% if album.coverImage %}
                                                    <img 
                                                        src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" 
                                                        alt="{{ album.title }}" 
                                                        class="w-full h-full object-cover"
                                                    >
                                                {% elseif album.photos|length > 0 %}
                                                    {% set firstPhoto = album.photos.first() %}
                                                    <img 
                                                        src="{{ asset('uploads/photos/' ~ firstPhoto.imageName) }}" 
                                                        alt="{{ album.title }}" 
                                                        class="w-full h-full object-cover"
                                                    >
                                                {% else %}
                                                    <div class="w-full h-full bg-gradient-to-br from-blue-100 to-purple-100 flex items-center justify-center">
                                                        <i class="fas fa-images text-gray-400 text-xl"></i>
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <!-- Badge public -->
                                            <span class="absolute -top-2 -right-2 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full">
                                                <i class="fas fa-globe-americas text-[8px]"></i>
                                            </span>
                                        </div>
                                        
                                        <!-- Titre et infos -->
                                        <div>
                                            <h2 class="text-xl md:text-2xl font-bold text-gray-800">
                                                {{ album.title }}
                                            </h2>
                                            <div class="flex items-center gap-3 mt-1">
                                                <span class="text-sm text-gray-500 flex items-center gap-1">
                                                    <i class="fas fa-calendar-alt text-xs"></i>
                                                    {{ album.eventDate|date('d/m/Y') }}
                                                </span>
                                                <span class="text-sm text-gray-500 flex items-center gap-1">
                                                    <i class="fas fa-image text-xs"></i>
                                                    {{ album.photos|length }} photo(s)
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Bouton voir tout -->
                                    <a href="{{ path('public_album_show', {id: album.id}) }}" 
                                       class="hidden md:flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-600 hover:bg-blue-100 rounded-lg transition-colors text-sm font-medium">
                                        <i class="fas fa-external-link-alt text-xs"></i>
                                        Voir tout
                                    </a>
                                </div>
                                
                                <!-- Carrousel horizontal des photos -->
                                <div class="album-carousel-container relative group">
                                    <!-- Bouton précédent -->
                                    <button class="carousel-nav-btn absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 bg-white hover:bg-gray-50 text-gray-800 rounded-full w-10 h-10 flex items-center justify-center shadow-lg hover:shadow-xl transition-all"
                                            onclick="scrollAlbumLeft('carousel-{{ album.id }}')"
                                            aria-label="Photos précédentes">
                                        <i class="fas fa-chevron-left"></i>
                                    </button>
                                    
                                    <!-- Carrousel -->
                                    <div id="carousel-{{ album.id }}" 
                                         class="album-carousel flex overflow-x-auto gap-4 md:gap-6 pb-6 scrollbar-thin scroll-smooth">
                                        {% for photo in album.photos %}
                                            <!-- Carte photo -->
                                            <div class="album-carousel-item w-[280px] flex-shrink-0">
                                                <div class="photo-card bg-white rounded-xl shadow-md overflow-hidden h-full border border-gray-100 cursor-pointer"
                                                     onclick="openLightbox('{{ album.id }}', {{ loop.index0 }})">
                                                    <!-- Image -->
                                                    <div class="relative aspect-square overflow-hidden">
                                                        <img 
                                                            src="{{ asset('uploads/photos/' ~ photo.imageName) }}" 
                                                            alt="{{ photo.title ? photo.title : 'Photo ' ~ loop.index }}" 
                                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                                            loading="lazy"
                                                            data-album-id="{{ album.id }}"
                                                            data-photo-index="{{ loop.index0 }}"
                                                        >
                                                        
                                                        <!-- Overlay -->
                                                        <div class="image-overlay absolute inset-0 flex items-end p-4">
                                                            <div class="text-white transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                                                                {% if photo.title %}
                                                                    <p class="text-sm font-medium mb-1 truncate">{{ photo.title }}</p>
                                                                {% endif %}
                                                                <p class="text-xs opacity-90 flex items-center gap-1">
                                                                    <i class="far fa-clock"></i>
                                                                    {{ photo.createdAt|date('d/m/Y') }}
                                                                </p>
                                                            </div>
                                                        </div>
                                                
                                                        <!-- Numéro -->
                                                        <div class="absolute top-3 left-3">
                                                            <span class="bg-black/60 text-white text-xs font-bold px-2 py-1 rounded-full">
                                                                #{{ loop.index }}
                                                            </span>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Infos basiques -->
                                                    <div class="p-4">
                                                        {% if photo.title %}
                                                            <h3 class="font-semibold text-gray-800 text-sm mb-2 truncate">
                                                                {{ photo.title }}
                                                            </h3>
                                                        {% endif %}
                                                        
                                                        {% if photo.description %}
                                                            <p class="text-gray-600 text-xs line-clamp-2 mb-3">
                                                                {{ photo.description }}
                                                            </p>
                                                        {% endif %}
                                                        
                                                    </div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    
                                    <!-- Bouton suivant -->
                                    <button class="carousel-nav-btn absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 bg-white hover:bg-gray-50 text-gray-800 rounded-full w-10 h-10 flex items-center justify-center shadow-lg hover:shadow-xl transition-all"
                                            onclick="scrollAlbumRight('carousel-{{ album.id }}')"
                                            aria-label="Photos suivantes">
                                        <i class="fas fa-chevron-right"></i>
                                    </button>
                                    
                                    <!-- Indicateur de scroll -->
                                    <div class="text-center mt-4">
                                        <div class="inline-flex items-center gap-1">
                                            {% for i in range(1, min(album.photos|length, 5)) %}
                                                <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                                            {% endfor %}
                                            {% if album.photos|length > 5 %}
                                                <span class="text-xs text-gray-500 ml-2">+{{ album.photos|length - 5 }} autres</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        <p>{{ album.comments|length }} commentaires</p>
                    {% endfor %}
                </div>
                
                <!-- Bouton retour -->
                <div class="text-center mt-12">
                    <a href="{{ path('app_home') }}" 
                       class="inline-flex items-center gap-3 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white font-semibold py-3 px-8 rounded-full transition-all duration-300 hover:shadow-lg hover:scale-105">
                        <i class="fas fa-home"></i>
                        Retour à l'accueil
                    </a>
                </div>
                
            {% else %}
                <!-- Message si aucun album public -->
                <div class="text-center py-12 md:py-16">
                    <div class="max-w-md mx-auto">
                        <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-2xl p-8 mb-6">
                            <i class="fas fa-folder-open text-5xl text-gray-300 mb-4"></i>
                            <h3 class="text-xl md:text-2xl font-bold text-gray-700 mb-3">
                                Aucun album public disponible
                            </h3>
                            <p class="text-gray-500 mb-4">
                                Les albums seront publiés ici lorsqu'ils seront marqués comme publics par l'administrateur.
                            </p>
                            <div class="h-1 w-20 bg-gradient-to-r from-blue-500 to-purple-500 mx-auto rounded-full"></div>
                        </div>
                        
                        <a href="{{ path('app_home') }}" 
                           class="inline-flex items-center gap-3 bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 px-6 rounded-full transition-all duration-300 hover:shadow-lg">
                            <i class="fas fa-arrow-left"></i>
                            Retour à l'accueil
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</section>

<!-- Lightbox/Fullscreen Viewer -->
<div id="lightbox" class="fixed inset-0 z-[100] hidden">
    <!-- Overlay sombre avec animation -->
    <div id="lightbox-overlay" 
         class="absolute inset-0 bg-black/0 transition-all duration-500"
         onclick="closeLightbox()">
    </div>
    
    <!-- Contenu de la lightbox -->
    <div class="relative z-10 h-full flex flex-col">
        <!-- En-tête -->
        <div class="flex items-center justify-between p-4 md:p-6 text-white">
            <div class="flex items-center gap-3">
                <button onclick="closeLightbox()" 
                        class="p-2 rounded-full hover:bg-white/10 transition-colors"
                        aria-label="Fermer">
                    <i class="fas fa-times text-xl"></i>
                </button>
                
                <div>
                    <h2 id="lightbox-album-title" class="font-semibold text-lg md:text-xl"></h2>
                    <p id="lightbox-photo-counter" class="text-sm opacity-80"></p>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                <button onclick="downloadCurrentPhoto()" 
                        class="p-2 rounded-full hover:bg-white/10 transition-colors"
                        aria-label="Télécharger">
                    <i class="fas fa-download"></i>
                </button>
                
                <button onclick="toggleFullscreen()" 
                        class="p-2 rounded-full hover:bg-white/10 transition-colors"
                        aria-label="Plein écran">
                    <i class="fas fa-expand"></i>
                </button>
            </div>
        </div>
        
        <!-- Zone d'image principale -->
        <div class="flex-1 flex items-center justify-center p-4">
            <!-- Bouton précédent -->
            <button id="lightbox-prev" 
                    onclick="prevPhoto()"
                    class="absolute left-4 top-1/2 -translate-y-1/2 p-3 rounded-full bg-black/40 hover:bg-black/60 text-white transition-all duration-200 opacity-0 hover:opacity-100"
                    aria-label="Photo précédente">
                <i class="fas fa-chevron-left text-xl"></i>
            </button>
            
            <!-- Image principale -->
            <div class="relative max-w-4xl w-full">
                <img id="lightbox-image" 
                     class="w-full h-auto max-h-[70vh] object-contain rounded-lg lightbox-image"
                     src="" 
                     alt=""
                     onload="imageLoaded()">
                
                <!-- Loader -->
                <div id="lightbox-loader" class="absolute inset-0 flex items-center justify-center">
                    <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-white"></div>
                </div>
                
                <!-- Infos photo -->
                <div id="lightbox-info" 
                     class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-4 md:p-6 text-white transform translate-y-full transition-transform duration-300">
                    <h3 id="lightbox-photo-title" class="font-bold text-lg md:text-xl mb-2"></h3>
                    <p id="lightbox-photo-description" class="text-sm opacity-90 mb-3"></p>
                    <div class="mt-4 text-xs opacity-70 flex items-center gap-4">
                        <span id="lightbox-photo-date"></span>
                        <span id="lightbox-photo-size"></span>
                    </div>
                </div>
            </div>
            
            <!-- Bouton suivant -->
            <button id="lightbox-next" 
                    onclick="nextPhoto()"
                    class="absolute right-4 top-1/2 -translate-y-1/2 p-3 rounded-full bg-black/40 hover:bg-black/60 text-white transition-all duration-200 opacity-0 hover:opacity-100"
                    aria-label="Photo suivante">
                <i class="fas fa-chevron-right text-xl"></i>
            </button>
        </div>
        
        <!-- Miniatures scrollables -->
        <div class="p-4 border-t border-white/10">
            <div class="max-w-4xl mx-auto">
                <div id="lightbox-thumbnails" 
                     class="flex overflow-x-auto gap-2 pb-2 scrollbar-thin scroll-smooth">
                    <!-- Les miniatures seront ajoutées dynamiquement -->
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        // ============================================
        // VARIABLES GLOBALES
        // ============================================
        let lightboxData = {
            currentAlbumId: null,
            currentPhotoIndex: 0,
            albums: {},
            isOpen: false
        };
        
        // ============================================
        // FONCTIONS DE CARROUSEL
        // ============================================
        function scrollAlbumLeft(carouselId) {
            const carousel = document.getElementById(carouselId);
            if (carousel) {
                carousel.scrollBy({ left: -300, behavior: 'smooth' });
            }
        }
        
        function scrollAlbumRight(carouselId) {
            const carousel = document.getElementById(carouselId);
            if (carousel) {
                carousel.scrollBy({ left: 300, behavior: 'smooth' });
            }
        }
        
        // ============================================
        // FONCTIONS DE LIGHTBOX
        // ============================================
        function openLightbox(albumId, photoIndex) {
            // Récupérer les données de l'album
            const albumSection = document.querySelector(`.album-section[data-album-id="${albumId}"]`);
            if (!albumSection) return;
            
            // Récupérer toutes les photos de l'album
            const photoCards = albumSection.querySelectorAll('.photo-card');
            const photos = Array.from(photoCards).map(card => {
                const img = card.querySelector('img');
                const title = card.querySelector('h3')?.textContent.trim() || '';
                const description = card.querySelector('.line-clamp-2')?.textContent.trim() || '';
                
                return {
                    src: img.src,
                    alt: img.alt,
                    title: title,
                    description: description,
                    date: card.querySelector('.fa-clock')?.parentElement?.textContent.trim() || ''
                };
            });
            
            // Stocker les données
            lightboxData.currentAlbumId = albumId;
            lightboxData.currentPhotoIndex = photoIndex;
            lightboxData.albums[albumId] = photos;
            
            // Récupérer le titre de l'album
            const albumTitle = albumSection.querySelector('h2').textContent.trim();
            
            // Afficher la lightbox
            showLightbox(albumTitle, photoIndex);
        }
        
        function showLightbox(albumTitle, photoIndex) {
            const lightbox = document.getElementById('lightbox');
            const overlay = document.getElementById('lightbox-overlay');
            const album = lightboxData.albums[lightboxData.currentAlbumId];
            const photo = album[photoIndex];
            
            // Afficher l'overlay avec animation
            lightbox.classList.remove('hidden');
            setTimeout(() => {
                overlay.classList.remove('bg-black/0');
                overlay.classList.add('bg-black/95');
            }, 10);
            
            // Mettre à jour les infos
            document.getElementById('lightbox-album-title').textContent = albumTitle;
            document.getElementById('lightbox-photo-counter').textContent = 
                `${photoIndex + 1} / ${album.length}`;
            
            // Afficher l'image
            const image = document.getElementById('lightbox-image');
            const loader = document.getElementById('lightbox-loader');
            
            image.style.opacity = '0';
            loader.classList.remove('hidden');
            
            image.src = photo.src;
            image.alt = photo.alt;
            
            // Mettre à jour les infos photo
            updatePhotoInfo(photo, photoIndex);
            
            // Mettre à jour les miniatures
            updateThumbnails(photoIndex);
            
            // Activer la navigation clavier
            lightboxData.isOpen = true;
            document.addEventListener('keydown', handleKeyboardNavigation);
            
            // Empêcher le scroll du body
            document.body.style.overflow = 'hidden';
        }
        
        function updatePhotoInfo(photo, index) {
            // Titre
            const titleEl = document.getElementById('lightbox-photo-title');
            titleEl.textContent = photo.title || 'Photo sans titre';
            
            // Description
            const descEl = document.getElementById('lightbox-photo-description');
            descEl.textContent = photo.description || '';
            descEl.style.display = photo.description ? 'block' : 'none';
            
            // Date
            const dateEl = document.getElementById('lightbox-photo-date');
            dateEl.textContent = photo.date || '';
            
            // Compteur
            const counterEl = document.getElementById('lightbox-photo-counter');
            const album = lightboxData.albums[lightboxData.currentAlbumId];
            counterEl.textContent = `${index + 1} / ${album.length}`;
        }
        
        function updateThumbnails(currentIndex) {
            const container = document.getElementById('lightbox-thumbnails');
            const album = lightboxData.albums[lightboxData.currentAlbumId];
            
            container.innerHTML = '';
            
            album.forEach((photo, index) => {
                const thumbnail = document.createElement('img');
                thumbnail.className = `lightbox-thumbnail w-16 h-16 object-cover rounded-lg cursor-pointer border-2 ${
                    index === currentIndex ? 'border-blue-500' : 'border-transparent'
                }`;
                thumbnail.src = photo.src;
                thumbnail.alt = `Miniature ${index + 1}`;
                thumbnail.loading = 'lazy';
                thumbnail.onclick = () => goToPhoto(index);
                
                container.appendChild(thumbnail);
            });
            
            // Scroll pour centrer la miniature active
            const activeThumb = container.children[currentIndex];
            if (activeThumb) {
                activeThumb.scrollIntoView({
                    behavior: 'smooth',
                    block: 'nearest',
                    inline: 'center'
                });
            }
        }
        
        function imageLoaded() {
            const image = document.getElementById('lightbox-image');
            const loader = document.getElementById('lightbox-loader');
            
            setTimeout(() => {
                image.style.opacity = '1';
                image.style.transition = 'opacity 0.3s ease';
                loader.classList.add('hidden');
            }, 100);
        }
        
        function goToPhoto(index) {
            if (index >= 0 && index < lightboxData.albums[lightboxData.currentAlbumId].length) {
                lightboxData.currentPhotoIndex = index;
                
                const albumTitle = document.getElementById('lightbox-album-title').textContent;
                const photo = lightboxData.albums[lightboxData.currentAlbumId][index];
                
                // Mettre à jour l'image avec effet de transition
                const image = document.getElementById('lightbox-image');
                image.style.opacity = '0';
                
                setTimeout(() => {
                    image.src = photo.src;
                    image.alt = photo.alt;
                    
                    // Mettre à jour les infos
                    updatePhotoInfo(photo, index);
                    updateThumbnails(index);
                    
                    // Afficher l'image
                    setTimeout(() => {
                        image.style.opacity = '1';
                    }, 50);
                }, 200);
            }
        }
        
        function prevPhoto() {
            if (lightboxData.currentPhotoIndex > 0) {
                goToPhoto(lightboxData.currentPhotoIndex - 1);
            }
        }
        
        function nextPhoto() {
            const album = lightboxData.albums[lightboxData.currentAlbumId];
            if (lightboxData.currentPhotoIndex < album.length - 1) {
                goToPhoto(lightboxData.currentPhotoIndex + 1);
            }
        }
        
        function closeLightbox() {
            const lightbox = document.getElementById('lightbox');
            const overlay = document.getElementById('lightbox-overlay');
            
            // Animation de fermeture
            overlay.classList.remove('bg-black/95');
            overlay.classList.add('bg-black/0');
            
            setTimeout(() => {
                lightbox.classList.add('hidden');
                lightboxData.isOpen = false;
                
                // Réactiver le scroll du body
                document.body.style.overflow = '';
                
                // Supprimer l'écouteur clavier
                document.removeEventListener('keydown', handleKeyboardNavigation);
            }, 500);
        }
        
        // ============================================
        // FONCTIONS AUXILIAIRES
        // ============================================
        function handleKeyboardNavigation(e) {
            if (!lightboxData.isOpen) return;
            
            switch(e.key) {
                case 'Escape':
                    closeLightbox();
                    break;
                case 'ArrowLeft':
                    prevPhoto();
                    break;
                case 'ArrowRight':
                    nextPhoto();
                    break;
                case ' ':
                    e.preventDefault();
                    nextPhoto();
                    break;
            }
        }
        
        function downloadCurrentPhoto() {
            const photo = lightboxData.albums[lightboxData.currentAlbumId][lightboxData.currentPhotoIndex];
            const link = document.createElement('a');
            link.href = photo.src;
            link.download = `photo-${lightboxData.currentAlbumId}-${lightboxData.currentPhotoIndex + 1}.jpg`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
        
        function toggleFullscreen() {
            const lightbox = document.getElementById('lightbox');
            
            if (!document.fullscreenElement) {
                lightbox.requestFullscreen().catch(err => {
                    console.log(`Erreur plein écran: ${err.message}`);
                });
            } else {
                document.exitFullscreen();
            }
        }
        
        // ============================================
        // INITIALISATION
        // ============================================
        document.addEventListener('DOMContentLoaded', function() {
            // Ajouter des écouteurs pour les carrousels
            document.querySelectorAll('.album-carousel').forEach(carousel => {
                carousel.addEventListener('wheel', function(e) {
                    if (e.deltaY !== 0) {
                        e.preventDefault();
                        this.scrollLeft += e.deltaY;
                    }
                });
            });
            
            // Cacher les boutons de navigation quand pas besoin
            document.querySelectorAll('.album-carousel').forEach(carousel => {
                const checkButtons = () => {
                    const prevBtn = carousel.previousElementSibling;
                    const nextBtn = carousel.nextElementSibling;
                    
                    if (carousel.scrollLeft <= 10) {
                        prevBtn?.classList.add('opacity-0', 'pointer-events-none');
                    } else {
                        prevBtn?.classList.remove('opacity-0', 'pointer-events-none');
                    }
                    
                    if (carousel.scrollLeft >= carousel.scrollWidth - carousel.clientWidth - 10) {
                        nextBtn?.classList.add('opacity-0', 'pointer-events-none');
                    } else {
                        nextBtn?.classList.remove('opacity-0', 'pointer-events-none');
                    }
                };
                
                carousel.addEventListener('scroll', checkButtons);
                checkButtons(); // Initial check
            });
            
            // Animation des cartes au scroll
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('fade-in');
                    }
                });
            }, { threshold: 0.1 });
            
            document.querySelectorAll('.photo-card').forEach(card => {
                observer.observe(card);
            });
        });
        
        // ============================================
        // EXPOSITION DES FONCTIONS GLOBALES
        // ============================================
        window.openLightbox = openLightbox;
        window.closeLightbox = closeLightbox;
        window.prevPhoto = prevPhoto;
        window.nextPhoto = nextPhoto;
        window.scrollAlbumLeft = scrollAlbumLeft;
        window.scrollAlbumRight = scrollAlbumRight;
    </script>
{% endblock %}
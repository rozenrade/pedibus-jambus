{# templates/public/gallery/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    {{ album.title }}
    - Pedibus Jambus
{% endblock %}

{% block body %}
    <section class="w-full px-4 py-8">
        <div class="max-w-7xl mx-auto">
            <div
            class="bg-white rounded-2xl shadow-xl p-6 md:p-8">
            <!-- En-tête de l'album -->
            <div class="mb-8">
                <a href="{{ path('public_album') }}" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 mb-4">
                    <i class="fas fa-arrow-left"></i>
                    Retour à la galerie
                </a>

                <h1 class="text-3xl font-bold text-gray-800 mb-2">{{ album.title }}</h1>
                <div class="flex flex-wrap items-center gap-4 text-gray-600">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-calendar-alt"></i>
                        {{ album.eventDate|date('d/m/Y') }}
                    </span>
                    <span class="flex items-center gap-2">
                        <i class="fas fa-images"></i>
                        {{ album.photos|length }}
                        photos
                    </span>
                    <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">
                        <i class="fas fa-globe-americas mr-1"></i>
                        Public
                    </span>
                </div>

                {% if album.description %}
                    <p class="mt-4 text-gray-600">{{ album.description }}</p>
                {% endif %}
            </div>

            <!-- Photos de l'album en grille -->
            {% if album.photos|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 items-start">
                    {% for photo in album.photos %}
                        <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">

                            <a href="{{ path('public_photo_image', {uuid: photo.uuid}) }}" target="_blank" class="block">
                                <img src="{{ ('uploads/photos/' ~ photo.imageName)|imagine_filter('gallery_grid') }}" alt="{{ photo.title ? photo.title : 'Photo ' ~ loop.index }}" class="w-full h-auto" loading="lazy">
                            </a>

                            <div class="p-4">

                                {% if photo.title %}
                                    <h3 class="font-semibold text-gray-800 mb-2">
                                        {{ photo.title }}
                                    </h3>
                                {% endif %}
                                {% if photo.description %}
                                    <h3 class="text-gray-500 mb-2">
                                        {{ photo.description }}
                                    </h3>
                                {% endif %}
                                <p class="text-sm text-blue-300">
                                    {{ photo.createdAt|date('d/m/Y') }}
                                </p>

                            </div>

                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-12">
                    <i class="fas fa-image text-5xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500">Cet album est vide pour l'instant!</p>
                </div>
            {% endif %}
        </div>
    </div>
    </section>

{% endblock %}

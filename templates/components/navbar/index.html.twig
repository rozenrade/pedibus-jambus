<div id="overlay" class="md:hidden fixed inset-0 bg-black bg-opacity-50 z-40 hidden"></div>


<script>
	document.addEventListener('DOMContentLoaded', function () {
initBurgerMenu();
});

document.addEventListener('turbo:load', initBurgerMenu);

function initBurgerMenu() {
const burgerBtn = document.getElementById('burger-btn');
const closeMenuBtn = document.getElementById('close-menu');
const mobileMenu = document.getElementById('mobile-menu');
const overlay = document.getElementById('overlay');
const burgerIcon = document.getElementById('burger-icon');

if (! burgerBtn || ! mobileMenu || ! burgerIcon) 
return;



let menuOpen = false;

function openMobileMenu() {
menuOpen = true;
mobileMenu.classList.remove('hidden');
overlay.classList.remove('hidden');
burgerIcon.classList.replace('fa-bars', 'fa-times');
document.body.style.overflow = 'hidden';
}

function closeMobileMenu() {
menuOpen = false;
mobileMenu.classList.add('hidden');
overlay.classList.add('hidden');
burgerIcon.classList.replace('fa-times', 'fa-bars');
document.body.style.overflow = '';
}

burgerBtn.onclick = openMobileMenu;
closeMenuBtn.onclick = closeMobileMenu;
overlay.onclick = closeMobileMenu;

document.addEventListener('keydown', function (e) {
if (e.key === 'Escape' && menuOpen) {
closeMobileMenu();
}
});

window.addEventListener('resize', function () {
if (window.innerWidth >= 768 && menuOpen) {
closeMobileMenu();
}
});

const menuLinks = mobileMenu.querySelectorAll('a');
menuLinks.forEach(link => {
link.addEventListener('click', function () {
setTimeout(closeMobileMenu, 200);
});
});
}
</script>

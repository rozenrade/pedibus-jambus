{% extends 'base.html.twig' %}

{% block title %}
    {{ album.title }}
{% endblock %}

{% block body %}
<div class="min-h-screen flex justify-center items-start py-16">

    <!-- Content wrapper -->
    <div class="w-full max-w-4xl bg-white bg-opacity-90 rounded-2xl shadow-lg p-8">

        <!-- Album Header -->
        <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold text-gray-900">{{ album.title }}</h1>
            <p class="text-gray-600 mt-2">
                {{ album.eventDate|date('d/m/Y') }}
                •
                {{ album.photos|length }} photo(s)
                •
                <span class="{{ album.isPublic ? 'text-green-600' : 'text-gray-500' }}">
                    {{ album.isPublic ? 'Public' : 'Privé' }}
                </span>
            </p>

            {% if album.description %}
                <div class="mt-4 p-4 bg-white rounded-lg shadow-sm max-w-2xl mx-auto">
                    <p class="text-gray-700">{{ album.description }}</p>
                </div>
            {% endif %}
        </div>

        <!-- Cover Image -->
        {% if album.coverImage %}
            <div class="mb-8 flex justify-center">
                <a href="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" target="_blank" rel="noopener noreferrer"> 
                <img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" 
                     alt="{{ album.title }}" 
                     class="w-full max-w-md rounded-lg shadow-md object-cover">
                </a>
            </div>
        {% endif %}

        <!-- Photos Grid -->
        <div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4 text-center">Photos</h2>

            {% if album.photos|length == 0 %}
                <div class="text-center py-12 bg-white rounded-lg border border-gray-200 shadow-sm">
                    <div class="text-gray-400 mb-4">
                        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900 mb-2">Aucune photo</h3>
                    <p class="text-gray-500">Cet album ne contient encore aucune photo.</p>
                </div>
            {% else %}
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    {% for photo in album.photos %}
                        <div class="bg-white rounded-lg overflow-hidden shadow-sm">
                            {% if photo.imageName %}
                                <div class="aspect-square overflow-hidden bg-gray-100">
                                <a href="{{ asset('uploads/photos/' ~ photo.imageName) }}" target="_blank" rel="noopener noreferrer"> 
                                    <img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" 
                                         alt="Photo" 
                                         class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
                                </a>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
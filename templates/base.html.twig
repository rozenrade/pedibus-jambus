<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}
				Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">
		<script src="https://cdn.tailwindcss.com"></script>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
		
		<!-- Désactiver Turbo pour éviter les problèmes -->
		<meta name="turbo-cache-control" content="no-cache">
		
		{% block stylesheets %}{% endblock %}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>

	<body class="bg-cyan-100 min-h-screen" data-turbo="false">

		<img src="{{ asset('img/blue-mountain.jpg') }}" class="fixed w-auto h-auto min-w-full min-h-full object-cover z-0" alt=""/>

		<div class="relative z-10">
			{{ include('components/navbar/index.html.twig') }}

			{% block body %}{% endblock %}
		</div>

	</body>
</html>
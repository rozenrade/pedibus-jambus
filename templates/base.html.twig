<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8"/>
		<title>
			{% block title %}
				Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">
		<script src="https://cdn.tailwindcss.com"></script>
		{% block stylesheets %}{% endblock %}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

	</head>

	<body class="bg-cyan-100 min-h-screen">

		<img src="{{ asset('img/blue-mountain.jpg') }}" class="fixed w-auto h-auto min-w-full min-h-full object-cover z-0" alt=""/>

		<div class="relative z-10">
			{{ include('components/navbar/index.html.twig') }}

			<!-- Notifications flash -->
			<div id="flash-notifications" class="fixed top-4 right-4 z-50 space-y-2">
				{% for type, messages in app.flashes(['success', 'error', 'warning', 'info']) %}
					{% for message in messages %}
						<div class="flash-notification flash-{{ type }} bg-white rounded-lg shadow-lg border p-4 max-w-sm transform transition-all duration-300 translate-x-full opacity-0">
							<div class="flex items-start">
								{% if type == 'success' %}
									<svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								{% elseif type == 'error' %}
									<svg class="w-6 h-6 text-red-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								{% elseif type == 'warning' %}
									<svg class="w-6 h-6 text-yellow-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.886-.833-2.656 0L4.138 16.5c-.77.833.192 2.5 1.732 2.5z"/>
									</svg>
								{% else %}
									<svg class="w-6 h-6 text-blue-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								{% endif %}
								<div class="flex-1">
									<p class="text-sm text-gray-800">{{ message }}</p>
								</div>
								<button type="button" class="ml-4 text-gray-400 hover:text-gray-600 close-flash">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
									</svg>
								</button>
							</div>
						</div>
					{% endfor %}
				{% endfor %}
			</div>

			{% block body %}{% endblock %}

			{% include 'components/footer/index.html.twig' %}
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', function () { // Afficher les notifications flash
const notifications = document.querySelectorAll('.flash-notification');

notifications.forEach((notification, index) => { // Animer l'entrée
setTimeout(() => {
notification.classList.remove('translate-x-full', 'opacity-0');
notification.classList.add('translate-x-0', 'opacity-100');
}, 100 * index);

// Fermer au bout de 3 secondes
setTimeout(() => {
notification.classList.add('translate-x-full', 'opacity-0');
setTimeout(() => {
notification.remove();
}, 300);
}, 3000 + (100 * index));

// Bouton de fermeture manuelle
const closeBtn = notification.querySelector('.close-flash');
if (closeBtn) {
closeBtn.addEventListener('click', () => {
notification.classList.add('translate-x-full', 'opacity-0');
setTimeout(() => {
notification.remove();
}, 300);
});
}
});
});
		</script>
	</body>
</html></body></html>

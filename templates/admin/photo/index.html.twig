{% extends 'base.html.twig' %}

{% block title %}Photos - Administration
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8">
		<div class="flex justify-between items-center mb-8">
			<div>
				<h1 class="text-3xl font-bold text-gray-900">Toutes les photos</h1>
				<p class="text-gray-600 mt-2">{{ photos|length }}
					photo(s)</p>
			</div>
			<a href="{{ path('admin_photo_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
				+ Nouvelle photo
			</a>
		</div>


		{% if photos|length == 0 %}
			<div class="text-center py-12">
				<div class="text-gray-400 mb-4">
					<svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
					</svg>
				</div>
				<h3 class="text-lg font-medium text-gray-900 mb-2">Aucune photo</h3>
				<p class="text-gray-500 mb-4">Commencez par ajouter des photos</p>
				<div class="flex justify-center space-x-4">
					<a href="{{ path('admin_photo_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
						+ Ajouter une photo
					</a>
					<a href="{{ path('admin_album_index') }}" class="bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-medium">
						Voir les albums
					</a>
				</div>
			</div>
		{% else %}
			<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
				{% for photo in photos %}
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
						{% if photo.imageName %}
							<div class="aspect-square overflow-hidden bg-gray-100">
								<img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="{{ photo.title }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
							</div>
						{% else %}
							<div class="aspect-square bg-gray-100 flex items-center justify-center">
								<svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
								</svg>
							</div>
						{% endif %}

						<div class="p-3">
							<div class="text-xs text-gray-500 mb-2">
								{{ photo.updatedAt|date('d/m/Y') }}
							</div>

							{% if photo.album %}
								<div class="mb-2">
									<span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">
										{{ photo.album.title }}
									</span>
								</div>
							{% else %}
								<div class="mb-2">
									<span class="inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">
										Sans album
									</span>
									<a href="{{ path('admin_photo_assign_to_album', {'id': photo.id}) }}" class="text-xs text-blue-600 hover:text-blue-800 ml-2">
										Assigner
									</a>
								</div>
							{% endif %}

							{% if photo.title %}
								<p class="text-sm font-medium text-gray-900 truncate mb-2">
									{{ photo.title }}
								</p>
							{% endif %}

							<div class="flex justify-between">
								<a href="{{ path('admin_photo_show', {'id': photo.id}) }}" class="text-blue-600 hover:text-blue-800 text-sm font-medium">
									Voir
								</a>
								<div class="flex space-x-2">
									<a href="{{ path('admin_photo_edit', {'id': photo.id}) }}" class="text-gray-600 hover:text-gray-800 text-sm">
										Modifier
									</a>
									<span class="text-gray-300">•</span>
									<a href="{{ path('admin_photo_delete', {'id': photo.id}) }}" class="text-red-600 hover:text-red-800 text-sm">
										Supprimer
									</a>
								</div>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</div>
{% endblock %}

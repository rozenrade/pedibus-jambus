{% extends 'base.html.twig' %}

{% block title %}Photo - Administration
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-4 py-8">
		<!-- En-tête -->
		<div class="mb-8">
			<div class="flex justify-between items-start">
				<div>
					<h1 class="text-3xl font-bold text-gray-900">Photo</h1>
					<div class="flex items-center space-x-4 mt-2 text-gray-600">
						<span>Ajoutée le
							{{ photo.updatedAt|date('d/m/Y à H:i') }}</span>
						{% if photo.album %}
							<span>•</span>
							<a href="{{ path('admin_album_show', {'id': photo.album.id}) }}" class="text-blue-600 hover:text-blue-800">
								Album :
								{{ photo.album.title }}
							</a>
						{% endif %}
					</div>
				</div>
				<div class="flex space-x-2">
					<a href="{{ path('admin_photo_edit', {'id': photo.id}) }}" class="bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-medium">
						Modifier
					</a>
					<a href="{{ path('admin_photo_delete', {'id': photo.id}) }}" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium">
						Supprimer
					</a>
				</div>
			</div>
		</div>

		<div
			class="grid grid-cols-1 lg:grid-cols-2 gap-8">
			<!-- Image -->
			<div>
				{% if photo.imageName %}
					<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
						<img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="Photo" class="w-full h-auto rounded-lg shadow-sm">
					</div>
				{% else %}
					<div class="bg-gray-100 rounded-lg h-96 flex items-center justify-center">
						<svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
						</svg>
					</div>
				{% endif %}
			</div>

			<!-- Informations et actions -->
			<div
				class="space-y-6">
				<!-- Métadonnées -->
				<div class="bg-white rounded-lg border border-gray-200 p-6">
					<h2 class="text-lg font-semibold text-gray-900 mb-4">Informations</h2>
					<div class="space-y-4">
						{% if photo.title %}
							<div>
								<p class="text-sm text-gray-500">Titre</p>
								<p class="font-medium text-gray-900">{{ photo.title }}</p>
							</div>
						{% endif %}

						{% if photo.description %}
							<div>
								<p class="text-sm text-gray-500">Description</p>
								<p class="text-gray-900">{{ photo.description }}</p>
							</div>
						{% endif %}

						{% if photo.tags %}
							<div>
								<p class="text-sm text-gray-500">Tags</p>
								<div class="flex flex-wrap gap-2 mt-1">
									{% for tag in photo.tags|split(',') %}
										{% if tag|trim %}
											<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
												{{ tag|trim }}
											</span>
										{% endif %}
									{% endfor %}
								</div>
							</div>
						{% endif %}

						<div>
							<p class="text-sm text-gray-500">Nom du fichier</p>
							<p class="font-mono text-sm text-gray-900">{{ photo.imageName }}</p>
						</div>
					</div>
				</div>

				<!-- Actions -->
				<div class="bg-white rounded-lg border border-gray-200 p-6">
					<h2 class="text-lg font-semibold text-gray-900 mb-4">Actions</h2>
					<div class="space-y-3">
						{% if photo.album %}
							<form action="{{ path('admin_photo_set_as_album_cover', {'id': photo.id}) }}" method="post" class="w-full">
								<input type="hidden" name="_token" value="{{ csrf_token('set-album-cover-' ~ photo.id) }}">
								<button type="submit" class="w-full text-left px-4 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700">
									<div class="flex items-center">
										<svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
											<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
										</svg>
										<div>
											<p class="font-medium">Définir comme couverture</p>
											<p class="text-sm text-gray-500">Définir cette photo comme couverture de l'album</p>
										</div>
									</div>
								</button>
							</form>

							<a href="{{ path('admin_photo_move_to_album', {'id': photo.id}) }}" class="block w-full text-left px-4 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700">
								<div class="flex items-center">
									<svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
									</svg>
									<div>
										<p class="font-medium">Déplacer vers un autre album</p>
										<p class="text-sm text-gray-500">Changer l'album de cette photo</p>
									</div>
								</div>
							</a>
						{% endif %}
						{% if not photo.album %}
							<a href="{{ path('admin_photo_assign_to_album', {'id': photo.id}) }}" class="block w-full text-left px-4 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 mb-3">
								<div class="flex items-center">
									<svg class="w-5 h-5 text-gray-500 mr-3" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
									</svg>
									<div>
										<p class="font-medium">Assigner à un album</p>
										<p class="text-sm text-gray-500">Ajouter cette photo à un album existant</p>
									</div>
								</div>
							</a>
						{% endif %}

						<div class="pt-3 border-t border-gray-100">
							<p class="text-sm text-gray-500 mb-2">Navigation</p>
							<div class="flex space-x-3">
								{% if photo.album %}
									<a href="{{ path('admin_album_show', {'id': photo.album.id}) }}" class="text-blue-600 hover:text-blue-800 font-medium">
										← Retour à l'album
									</a>
								{% endif %}
								<a href="{{ path('admin_photo_index') }}" class="text-gray-600 hover:text-gray-800 font-medium">
									Voir toutes les photos
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Modifier la photo - Administration
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8 max-w-2xl">
		<div class="mb-8">
			<h1 class="text-3xl font-bold text-gray-900">Modifier la photo</h1>
			<p class="text-gray-600 mt-2">
				{% if photo.album %}
					Album :
					<a href="{{ path('admin_album_show', {'id': photo.album.id}) }}" class="text-blue-600 hover:text-blue-800">{{ photo.album.title }}</a>
				{% else %}
					Photo sans album
				{% endif %}
			</p>
		</div>

		{% for message in app.flashes('success') %}
			<div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}

		<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
			{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

			<div>
				{{ form_label(form.imageFile, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.imageFile, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.imageFile) }}
				<p class="text-sm text-gray-500 mt-1">Laissez vide pour conserver l'image actuelle</p>

				{% if photo.imageName %}
					<div class="mt-4">
						<p class="text-sm text-gray-600 mb-2">Image actuelle :</p>
						<img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="Photo actuelle" class="max-w-xs rounded border border-gray-200">
					</div>
				{% endif %}
			</div>

			<div>
				{{ form_label(form.title, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.title, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.title) }}
			</div>

			<div>
				{{ form_label(form.description, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500', 'rows': 3}}) }}
				{{ form_errors(form.description) }}
			</div>

			<div>
				{{ form_label(form.tags, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.tags, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				<p class="text-sm text-gray-500 mt-1">Séparés par des virgules</p>
				{{ form_errors(form.tags) }}
			</div>

			<div class="flex justify-between pt-6 border-t border-gray-200">
				<a href="{{ path('admin_photo_show', {'id': photo.id}) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
					Annuler
				</a>
				<div class="flex space-x-3">
					<a href="{{ path('admin_photo_delete', {'id': photo.id}) }}" class="px-4 py-2 border border-red-300 text-red-700 rounded-lg hover:bg-red-50">
						Supprimer
					</a>
					<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
						Enregistrer les modifications
					</button>
				</div>
			</div>

			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}

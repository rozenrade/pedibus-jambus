{# templates/admin/photo/assign_to_album.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Assigner à un album -
	{{ photo.title|default('Photo sans titre') }}
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8 max-w-2xl">
		<div class="mb-8">
			<div class="flex items-center space-x-3 mb-4">
				<a href="{{ path('admin_photo_show', {'id': photo.id}) }}" class="text-blue-600 hover:text-blue-800">
					← Retour à la photo
				</a>
				<span class="text-gray-400">/</span>
				<h1 class="text-2xl font-bold text-gray-900">Assigner à un album</h1>
			</div>
			<p class="text-gray-600">Assignez cette photo à un album existant</p>
		</div>

		<div
			class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
			<!-- Prévisualisation de la photo -->
			<div class="mb-6">
				<h3 class="font-medium text-gray-900 mb-3">Photo à assigner</h3>
				<div class="flex items-center space-x-4">
					{% if photo.imageName %}
						<div class="w-24 h-24 rounded overflow-hidden bg-gray-100 flex-shrink-0">
							<img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="{{ photo.title|default('Photo') }}" class="w-full h-full object-cover">
						</div>
					{% endif %}
					<div>
						{% if photo.title %}
							<h4 class="font-medium text-gray-900">{{ photo.title }}</h4>
						{% endif %}
						<p class="text-sm text-gray-500">
							Ajoutée le
							{{ photo.createdAt|date('d/m/Y à H:i') }}
						</p>
						{% if photo.tags %}
							<div class="mt-2 flex flex-wrap gap-1">
								{% for tag in photo.tags %}
									<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
										{{ tag }}
									</span>
								{% endfor %}
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<!-- Formulaire de sélection d'album -->
			<form method="post">
				<div class="mb-6">
					<label for="album_id" class="block mb-2 font-medium text-gray-900">
						Sélectionnez un album *
					</label>
					<select name="album_id" id="album_id" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
						<option value="">-- Choisir un album --</option>
						{% for album in albums %}
							<option value="{{ album.id }}">
								{{ album.title }}
								({{ album.photos|length }}
								photos,
								{{ album.isPublic ? 'public' : 'privé' }})
							</option>
						{% endfor %}
					</select>
					<p class="text-sm text-gray-500 mt-1">
						Choisissez l'album dans lequel vous souhaitez ajouter cette photo.
					</p>
				</div>

				<input type="hidden" name="_token" value="{{ csrf_token('assign-photo-' ~ photo.id) }}">

				<div class="flex justify-between pt-6 border-t border-gray-200">
					<a href="{{ path('admin_photo_show', {'id': photo.id}) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
						Annuler
					</a>
					<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
						Assigner à l'album
					</button>
				</div>
			</form>
		</div>

		<!-- Liste des albums disponibles -->
		<div class="mt-8">
			<h2 class="text-lg font-semibold text-gray-900 mb-4">Albums disponibles</h2>
			{% if albums|length == 0 %}
				<div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
					<p class="text-yellow-800">
						Aucun album disponible.
						<a href="{{ path('admin_album_new') }}" class="font-medium underline">
							Créez un album d'abord
						</a>.
					</p>
				</div>
			{% else %}
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					{% for album in albums|slice(0, 4) %}
						<div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
							<div class="flex items-start">
								{% if album.coverImage %}
									<div class="w-16 h-16 rounded overflow-hidden bg-gray-100 mr-3 flex-shrink-0">
										<img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" alt="{{ album.title }}" class="w-full h-full object-cover">
									</div>
								{% endif %}
								<div>
									<h3 class="font-medium text-gray-900">{{ album.title }}</h3>
									<p class="text-sm text-gray-500">
										{{ album.photos|length }}
										photos •
										{{ album.eventDate|date('d/m/Y') }}
									</p>
									<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mt-1 {{ album.isPublic ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' }}">
										{{ album.isPublic ? 'Public' : 'Privé' }}
									</span>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
				{% if albums|length > 4 %}
					<div class="mt-4 text-center">
						<p class="text-sm text-gray-500">
							{{ albums|length - 4 }}
							autres albums disponibles dans la liste déroulante
						</p>
					</div>
				{% endif %}
			{% endif %}
		</div>
	</div>
{% endblock %}

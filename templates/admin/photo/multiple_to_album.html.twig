{% extends 'base.html.twig' %}

{% block title %}Upload multiple - {{ album.title }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="mb-8">
        <div class="flex items-center space-x-3 mb-4">
            <a href="{{ path('admin_album_show', {'id': album.id}) }}" 
               class="text-blue-600 hover:text-blue-800">
                ← Retour à l'album
            </a>
            <span class="text-gray-400">/</span>
            <h1 class="text-2xl font-bold text-gray-900">Upload multiple</h1>
        </div>
        <p class="text-gray-600">Ajoutez plusieurs photos à l'album : <strong>{{ album.title }}</strong></p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
            <div>
                {{ form_label(form.images, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
                {{ form_widget(form.images, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                {{ form_errors(form.images) }}
                <p class="text-sm text-gray-500 mt-1">Sélectionnez plusieurs fichiers (Ctrl+clic). Formats : JPG, PNG, WebP, GIF. Max 10MB par fichier.</p>
            </div>

            <div>
                {{ form_label(form.tags, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
                {{ form_widget(form.tags, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                <p class="text-sm text-gray-500 mt-1">Ces tags seront appliqués à toutes les photos (optionnel)</p>
                {{ form_errors(form.tags) }}
            </div>

            <div class="flex justify-between pt-6 border-t border-gray-200">
                <div class="flex space-x-3">
                    <a href="{{ path('admin_album_show', {'id': album.id}) }}" 
                       class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Annuler
                    </a>
                    <a href="{{ path('admin_photo_new_to_album', {'albumId': album.id}) }}" 
                       class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Upload simple
                    </a>
                </div>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
                    Uploader les photos
                </button>
            </div>

        {{ form_end(form) }}
    </div>

    <div class="mt-8 p-4 bg-blue-50 border border-blue-100 rounded-lg">
        <div class="flex">
            <svg class="w-5 h-5 text-blue-600 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
            <div>
                <h3 class="text-sm font-medium text-blue-800">Conseils pour l'upload multiple</h3>
                <div class="mt-1 text-sm text-blue-700">
                    <ul class="list-disc list-inside space-y-1">
                        <li>Vous pouvez sélectionner jusqu'à 20 fichiers à la fois</li>
                        <li>Les noms des fichiers seront conservés</li>
                        <li>Les photos seront ajoutées dans l'ordre de sélection</li>
                        <li>L'upload peut prendre quelques secondes selon le nombre de fichiers</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{# templates/admin/hiking_program/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier programme - PEDIBUS JAMBUS
{% endblock %}

{% block body %}
	<div class="min-h-screen bg-gray-50 p-4">
		<div
			class="max-w-2xl mx-auto">
			<!-- Navigation -->
			<div class="mb-8">
				<a href="{{ path('admin_programs_index') }}" class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-6">
					<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
					</svg>
					Retour à la liste
				</a>
				<h1 class="text-2xl font-bold text-gray-900">Modifier le programme</h1>
				<p class="text-gray-600 mt-2">Modifiez les informations du programme.</p>
			</div>

			<!-- Messages flash -->
			{% for message in app.flashes('success') %}
				<div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
					{{ message }}
				</div>
			{% endfor %}

			{% for message in app.flashes('error') %}
				<div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
					{{ message }}
				</div>
			{% endfor %}

			<!-- Formulaire -->
			<div class="bg-white rounded-lg border shadow-sm p-6">
				{{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}

				<!-- Titre -->
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">
						Titre du programme *
					</label>
					{{ form_widget(form.title, {'attr': {
						'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500',
						'placeholder': 'Ex: Programme du 1er trimestre 2024'
					}}) }}
					<div class="text-red-500 text-sm mt-1">
						{{ form_errors(form.title) }}
					</div>
				</div>

				<!-- Année et Trimestre -->
				<div
					class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<!-- Année -->
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-2">
							Année *
						</label>
						{{ form_widget(form.year, {'attr': {
							'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500'
						}}) }}
						<div class="text-red-500 text-sm mt-1">
							{{ form_errors(form.year) }}
						</div>
					</div>

					<!-- Trimestre -->
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-2">
							Type de programme
						</label>
						{{ form_widget(form.quarter, {'attr': {
							'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500'
						}}) }}
						<div class="text-red-500 text-sm mt-1">
							{{ form_errors(form.quarter) }}
						</div>
					</div>
				</div>

				<!-- Description -->
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-2">
						Description
						<span class="text-gray-400 text-sm">(optionnel)</span>
					</label>
					{{ form_widget(form.description, {'attr': {
						'class': 'w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500',
						'rows': 4,
						'placeholder': 'Description du programme...'
					}}) }}
					<div class="text-red-500 text-sm mt-1">
						{{ form_errors(form.description) }}
					</div>
				</div>

				<!-- PDF -->
				<div class="border-t pt-6">
					<div class="flex items-center mb-4">
						<svg class="w-5 h-5 text-red-500 mr-2" fill="currentColor" viewbox="0 0 20 20">
							<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
						</svg>
						<label class="block text-sm font-medium text-gray-700">
							Fichier PDF
						</label>
					</div>

					<!-- Afficher le PDF actuel -->
					{% if program.pdfName %}
						<div class="mb-4 p-4 bg-gray-50 rounded-lg">
							<div class="flex items-center">
								<svg class="w-8 h-8 text-red-500 mr-3" fill="currentColor" viewbox="0 0 20 20">
									<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
								</svg>
								<div class="flex-1">
									<p class="font-medium text-gray-900">{{ program.pdfName }}</p>
									<p class="text-sm text-gray-500">{{ (program.pdfSize / 1024)|round(2) }}
										Ko</p>
								</div>
								<a href="{{ program.pdfUrl }}" target="_blank" class="ml-4 px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-lg hover:bg-blue-200">
									Voir
								</a>
							</div>
						</div>
						<p class="text-sm text-gray-600 mb-4">
							Un nouveau fichier remplacera celui-ci. Laissez vide pour conserver le PDF actuel.
						</p>
					{% endif %}

					<!-- Zone de téléchargement -->
					<div id="fileDropZone" class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-green-400 transition-colors">
						<svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
						</svg>

						<div id="uploadArea">
							<p class="text-sm text-gray-600 mb-2">
								Cliquez pour sélectionner un nouveau fichier PDF
							</p>
							<p class="text-xs text-gray-500 mb-4">
								Maximum 5 Mo
							</p>

							<!-- Champ file caché -->
							<div style="display: none;">
								{{ form_widget(form.pdfFile) }}
							</div>

							<button type="button" id="selectFileBtn" class="inline-flex items-center px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 cursor-pointer">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
								</svg>
								Choisir un fichier
							</button>
						</div>

						<!-- Afficher le nom du fichier -->
						<div id="fileInfo" class="hidden mt-4">
							<div class="flex items-center justify-center bg-gray-50 p-3 rounded-lg">
								<svg class="w-6 h-6 text-red-500 mr-3" fill="currentColor" viewbox="0 0 20 20">
									<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
								</svg>
								<div class="text-left">
									<p id="fileName" class="font-medium text-gray-900 text-sm"></p>
									<button type="button" id="removeFileBtn" class="text-red-600 hover:text-red-800 text-xs mt-1">
										Supprimer
									</button>
								</div>
							</div>
						</div>
					</div>

					<div class="text-red-500 text-sm mt-2">
						{{ form_errors(form.pdfFile) }}
					</div>

					<div class="mt-4 text-sm text-gray-600">
						<p class="font-medium mb-1">Informations :</p>
						<ul class="text-gray-500 space-y-1">
							<li class="flex items-start">
								<span class="mr-2">•</span>
								Format PDF uniquement
							</li>
							<li class="flex items-start">
								<span class="mr-2">•</span>
								Maximum 5 Mo
							</li>
							<li class="flex items-start">
								<span class="mr-2">•</span>
								Laissez vide pour conserver le fichier actuel
							</li>
						</ul>
					</div>
				</div>

				<!-- Boutons -->
				<div class="flex justify-end space-x-4 pt-6 border-t">
					<a href="{{ path('admin_programs_index') }}" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
						Annuler
					</a>
					<button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
						Mettre à jour
					</button>
				</div>

				{{ form_end(form) }}
			</div>
		</div>
	</div>

<script>
	// SOLUTION POUR TURBO - Version simple et fiable
	function initFileUpload() {
		console.log('Initialisation du upload...');
		
		const fileInput = document.querySelector('input[type="file"]');
		const selectBtn = document.getElementById('selectFileBtn');
		const fileName = document.getElementById('fileName');
		const uploadArea = document.getElementById('uploadArea');
		const fileInfo = document.getElementById('fileInfo');
		const removeBtn = document.getElementById('removeFileBtn');
		
		// Vérifier que les éléments existent
		if (!fileInput || !selectBtn) {
			console.log('Éléments non trouvés, nouvelle tentative...');
			// Réessayer dans 100ms
			setTimeout(initFileUpload, 100);
			return;
		}
		
		console.log('Éléments trouvés, configuration...');
		
		// 1. Cacher l'input natif
		fileInput.style.display = 'none';
		
		// 2. Réinitialiser l'affichage
		if (fileInput.value === '') {
			if (uploadArea) uploadArea.classList.remove('hidden');
			if (fileInfo) fileInfo.classList.add('hidden');
		}
		
		// 3. NETTOYER LES ANCIENS ÉCOUTEURS (IMPORTANT POUR TURBO)
		selectBtn.replaceWith(selectBtn.cloneNode(true));
		fileInput.replaceWith(fileInput.cloneNode(true));
		
		// 4. Récupérer les nouveaux éléments après clonage
		const newFileInput = document.querySelector('input[type="file"]');
		const newSelectBtn = document.getElementById('selectFileBtn');
		
		if (!newFileInput || !newSelectBtn) {
			console.error('Éléments manquants après clonage');
			return;
		}
		
		// Cacher le nouvel input
		newFileInput.style.display = 'none';
		
		// 5. Configurer le bouton (utiliser onclick pour éviter l'accumulation)
		newSelectBtn.onclick = function() {
			console.log('Bouton cliqué!');
			newFileInput.click();
		};
		
		// 6. Gérer le changement de fichier
		newFileInput.onchange = function() {
			console.log('Fichier sélectionné');
			if (this.files.length > 0) {
				const file = this.files[0];
				
				// Validation
				if (file.type !== 'application/pdf') {
					alert('Veuillez sélectionner un fichier PDF.');
					this.value = '';
					return;
				}
				
				if (file.size > 5 * 1024 * 1024) {
					alert('Le fichier est trop volumineux. Maximum 5 MB.');
					this.value = '';
					return;
				}
				
				// Afficher infos
				if (fileName) fileName.textContent = file.name;
				if (uploadArea) uploadArea.classList.add('hidden');
				if (fileInfo) fileInfo.classList.remove('hidden');
			}
		};
		
		// 7. Bouton supprimer
		if (removeBtn) {
			const newRemoveBtn = document.getElementById('removeFileBtn');
			if (newRemoveBtn) {
				newRemoveBtn.onclick = function(e) {
					e.stopPropagation();
					newFileInput.value = '';
					if (uploadArea) uploadArea.classList.remove('hidden');
					if (fileInfo) fileInfo.classList.add('hidden');
				};
			}
		}
		
		console.log('Upload configuré avec succès!');
	}
	
	// ===== GESTION DES ÉVÉNEMENTS TURBO =====
	
	// Événement pour Turbo quand une nouvelle page est chargée
	document.addEventListener('turbo:load', function() {
		console.log('Turbo:load - Page chargée via Turbo');
		setTimeout(initFileUpload, 50);
	});
	
	// Événement pour le premier chargement (sans Turbo)
	document.addEventListener('DOMContentLoaded', function() {
		console.log('DOMContentLoaded - Premier chargement');
		setTimeout(initFileUpload, 100);
	});
	
	// Événement pour quand Turbo prépare une nouvelle page
	document.addEventListener('turbo:before-render', function() {
		console.log('Turbo:before-render - Préparation nouvelle page');
		// Nettoyer avant le rendu de la nouvelle page
		const fileInput = document.querySelector('input[type="file"]');
		const selectBtn = document.getElementById('selectFileBtn');
		
		if (selectBtn) {
			selectBtn.onclick = null;
		}
		if (fileInput) {
			fileInput.onchange = null;
		}
	});
	
	// Désactiver Turbo pour les formulaires d'upload si nécessaire
	document.addEventListener('turbo:submit-start', function(event) {
		const form = event.target;
		if (form && form.querySelector('input[type="file"]')) {
			console.log('Form avec fichier détecté, traitement normal');
		}
	});
</script>
{% endblock %}

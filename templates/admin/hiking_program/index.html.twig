{# templates/admin/hiking_program/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Programmes
{% endblock %}

{% block body %}
	<div class="min-h-screen bg-gray-50 p-4">
		<div class="max-w-6xl mx-auto">
			<!-- Header -->
			<div class="mb-6 flex justify-between items-center">
				<h1 class="text-2xl font-bold text-gray-800">Programmes de randonnée</h1>
				<a href="{{ path('admin_programs_new') }}" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
					+ Nouveau
				</a>
			</div>

			<!-- Liste groupée par année -->
			{% if groupedPrograms|length > 0 %}
				{% for year, programs in groupedPrograms %}
					<div class="mb-8">
						<h2 class="text-xl font-bold text-gray-700 mb-4 flex items-center">
							<span class="bg-gray-800 text-white px-3 py-1 rounded-lg mr-3">{{ year }}</span>
							<span class="text-gray-600 text-sm">{{ programs|length }} programme(s)</span>
						</h2>
						
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
							{% for program in programs %}
								<div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
									<div class="mb-3">
										<h3 class="font-bold text-gray-900">{{ program.title }}</h3>
										<div class="mt-1">
											{% if program.quarter %}
												<span class="inline-block px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded">
													{{ program.quarter }}er trimestre
												</span>
											{% else %}
												<span class="inline-block px-2 py-1 text-xs bg-green-100 text-green-800 rounded">
													Sorties Grandes Évasions
												</span>
											{% endif %}
										</div>
									</div>

									{% if program.description %}
										<p class="text-gray-600 text-sm mb-4 line-clamp-2">{{ program.description }}</p>
									{% endif %}

									<div class="flex justify-between items-center">
										<div>
											{% if program.pdfName %}
												<a href="{{ program.pdfUrl }}" target="_blank" class="inline-flex items-center text-sm text-blue-600 hover:text-blue-800">
													<svg class="w-4 h-4 mr-1 text-red-500" fill="currentColor" viewbox="0 0 20 20">
														<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
													</svg>
													PDF disponible
												</a>
											{% else %}
												<span class="text-sm text-gray-400">Aucun PDF</span>
											{% endif %}
										</div>

										<div class="flex space-x-2">
											<a href="{{ path('admin_programs_edit', {'id': program.id}) }}" class="p-1 text-blue-600 hover:text-blue-800" title="Modifier">
												<svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
												</svg>
											</a>
											<form method="post" action="{{ path('admin_programs_delete', {'id': program.id}) }}" onsubmit="return confirm('Supprimer ?');">
												<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ program.id) }}">
												<button type="submit" class="p-1 text-red-600 hover:text-red-800" title="Supprimer">
													<svg class="w-5 h-5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
													</svg>
												</button>
											</form>
										</div>
									</div>
									
									<!-- Date de mise à jour -->
									{% if program.updateAt %}
										<div class="mt-4 pt-4 border-t border-gray-100 text-xs text-gray-500">
											Dernière mise à jour : {{ program.updateAt|date('d/m/Y') }}
										</div>
									{% endif %}
								</div>
							{% endfor %}
						</div>
					</div>
				{% endfor %}
			{% else %}
				<div class="bg-white border border-gray-200 rounded-lg p-8 text-center">
					<svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
					</svg>
					<p class="text-gray-600 mb-4">Aucun programme pour le moment</p>
					<a href="{{ path('admin_programs_new') }}" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
						<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
						</svg>
						Créer le premier programme
					</a>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
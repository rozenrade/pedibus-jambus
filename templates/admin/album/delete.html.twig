{% extends 'base.html.twig' %}

{% block title %}Supprimer
	{{ album.title }}
	- Administration
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8 max-w-2xl">
		<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
			<div class="text-center mb-6">
				<div class="mx-auto w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-4">
					<svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
					</svg>
				</div>
				<h1 class="text-2xl font-bold text-gray-900 mb-2">Supprimer l'album</h1>
				<p class="text-gray-600">Êtes-vous sûr de vouloir supprimer cet album ?</p>
			</div>

			<div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
				<h2 class="font-semibold text-red-800 mb-2">{{ album.title }}</h2>
				<ul class="text-sm text-red-700 space-y-1">
					<li>• Date :
						{{ album.eventDate|date('d/m/Y') }}</li>
					<li>• Photos :
						{{ album.photos|length }}
						photo(s)</li>
					<li>• Statut :
						{{ album.isPublic ? 'Public' : 'Privé' }}</li>
				</ul>
			</div>

			{% if album.photos|length > 0 %}
				<div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
					<div class="flex">
						<svg class="w-5 h-5 text-yellow-600 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewbox="0 0 20 20">
							<path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
						</svg>
						<div>
							<h3 class="text-sm font-medium text-yellow-800">Attention !</h3>
							<div class="mt-1 text-sm text-yellow-700">
								<p>Cet album contient
									{{ album.photos|length }}
									photo(s). Toutes les photos seront également supprimées.</p>
								<p class="mt-1">Si vous souhaitez conserver les photos, supprimez-les d'abord individuellement.</p>
							</div>
						</div>
					</div>
				</div>
			{% endif %}

			<div class="flex justify-between pt-6 border-t border-gray-200">
				<a href="{{ path('admin_album_show', {'id': album.id}) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
					Annuler
				</a>
				<form method="post">
					<input type="hidden" name="_token" value="{{ csrf_token('delete-album-' ~ album.id) }}">
					<button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium">
						Oui, supprimer définitivement
					</button>
				</form>
			</div>
		</div>
	</div>
{% endblock %}

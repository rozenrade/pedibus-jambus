{% extends 'base.html.twig' %}

{% block title %}Modifier
	{{ album.title }}
	- Administration
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8 max-w-4xl">
		<div class="mb-8">
			<h1 class="text-3xl font-bold text-gray-900">Modifier l'album</h1>
			<p class="text-gray-600 mt-2">{{ album.title }}</p>
		</div>

		{% for message in app.flashes('success') %}
			<div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}

		<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
			{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

			<div>
				{{ form_label(form.title, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.title, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.title) }}
			</div>

			<div>
				{{ form_label(form.description, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500', 'rows': 4}}) }}
				{{ form_errors(form.description) }}
			</div>

			<div>
				{{ form_label(form.eventDate, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.eventDate, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.eventDate) }}
			</div>

			<div class="flex items-center">
				{{ form_widget(form.isPublic, {'attr': {'class': 'h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500'}}) }}
				{{ form_label(form.isPublic, null, {'label_attr': {'class': 'ml-2 text-gray-900'}}) }}
				{{ form_errors(form.isPublic) }}
			</div>

			<div>
				{{ form_label(form.coverImageFile, null, {'label_attr': {'class': 'block mb-2 font-medium text-gray-900'}}) }}
				{{ form_widget(form.coverImageFile, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
				{{ form_errors(form.coverImageFile) }}
				<p class="text-sm text-gray-500 mt-1">Laissez vide pour conserver l'image actuelle</p>

				{% if album.coverImage %}
					<div class="mt-4">
						<p class="text-sm text-gray-600 mb-2">Image actuelle :</p>
						<img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" alt="Couverture actuelle" class="max-w-xs rounded border border-gray-200">
					</div>
				{% endif %}
			</div>

			<div class="flex justify-between pt-6 border-t border-gray-200">
				<a href="{{ path('admin_album_show', {'id': album.id}) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
					Annuler
				</a>
				<div class="flex space-x-3">
					<a href="{{ path('admin_album_delete', {'id': album.id}) }}" class="px-4 py-2 border border-red-300 text-red-700 rounded-lg hover:bg-red-50">
						Supprimer
					</a>
					<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
						Enregistrer les modifications
					</button>
				</div>
			</div>

			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Nouvel album - Administration{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50/30">
    <!-- Header avec navigation amélioré -->
    <div class="sticky top-0 z-10 bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-200/80">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-wrap justify-between items-center py-4 gap-4">
                <div class="flex items-center space-x-4">
                    <a href="{{ path('admin_dashboard') }}" 
                       class="group p-2 -ml-2 rounded-full text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                    </a>
                    <div>
                        <h1 class="text-2xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 bg-clip-text text-transparent">Nouvel album</h1>
                        <p class="text-sm text-gray-500 mt-0.5">Créez un album pour organiser vos photos</p>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="hidden sm:flex items-center text-sm text-gray-500 bg-gray-100 px-3 py-1.5 rounded-full">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        {{ "now"|date("d/m/Y") }}
                    </div>
                    <div class="relative group">
                        <div class="w-9 h-9 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-full flex items-center justify-center text-white font-semibold text-sm shadow-md ring-2 ring-white">
                            {{ app.user.email|first|upper }}
                        </div>
                        <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                            <div class="p-2">
                                <p class="text-xs text-gray-500 px-3 py-2">Connecté en tant que</p>
                                <p class="text-sm font-medium text-gray-900 px-3 pb-2 truncate">{{ app.user.email }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenu principal -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col xl:flex-row gap-8">
            <!-- Sidebar améliorée -->
            <div class="xl:w-1/4 space-y-6">
                <!-- Card conseils avec gradient -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow duration-300">
                    <div class="bg-gradient-to-r from-blue-50 to-white px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center">
                            <div class="w-8 h-8 bg-blue-100 rounded-xl flex items-center justify-center">
                                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <h3 class="ml-3 font-semibold text-gray-900">Conseils pro</h3>
                        </div>
                    </div>
                    <div class="p-6">
                        <ul class="space-y-4">
                            <li class="flex items-start group">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-green-100 text-green-600 flex items-center justify-center mt-0.5 group-hover:scale-110 transition-transform">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <span class="ml-3 text-sm text-gray-600 group-hover:text-gray-900">Titre clair et descriptif (max 60 caractères recommandé)</span>
                            </li>
                            <li class="flex items-start group">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-green-100 text-green-600 flex items-center justify-center mt-0.5 group-hover:scale-110 transition-transform">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <span class="ml-3 text-sm text-gray-600 group-hover:text-gray-900">Date précise pour un meilleur classement</span>
                            </li>
                            <li class="flex items-start group">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-green-100 text-green-600 flex items-center justify-center mt-0.5 group-hover:scale-110 transition-transform">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <span class="ml-3 text-sm text-gray-600 group-hover:text-gray-900">Image de couverture 16:9 pour une meilleure intégration</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Progression interactive -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
                    <h3 class="font-semibold text-gray-900 mb-5 flex items-center">
                        <span class="w-1 h-5 bg-blue-500 rounded-full mr-3"></span>
                        Étapes de création
                    </h3>
                    <div class="space-y-5">
                        {% set steps = [
                            {name: 'Informations', desc: 'Titre et description', active: true},
                            {name: 'Paramètres', desc: 'Date et visibilité', active: false},
                            {name: 'Couverture', desc: 'Image principale', active: false}
                        ] %}
                        {% for step in steps %}
                        <div class="flex items-center group">
                            <div class="flex-shrink-0 w-8 h-8 rounded-full {{ step.active ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 text-gray-500' }} flex items-center justify-center text-sm font-bold transition-all group-hover:scale-105">
                                {{ loop.index }}
                            </div>
                            <div class="ml-4">
                                <p class="font-medium {{ step.active ? 'text-gray-900' : 'text-gray-500' }}">{{ step.name }}</p>
                                <p class="text-xs {{ step.active ? 'text-blue-600' : 'text-gray-400' }}">{{ step.desc }}</p>
                            </div>
                            {% if step.active %}
                            <div class="ml-auto">
                                <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            {% endif %}
                        </div>
                        {% if not loop.last %}
                        <div class="ml-4 border-l-2 border-dashed border-gray-200 h-3"></div>
                        {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Actions rapides avec hover effect -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                    <h3 class="font-semibold text-gray-900 mb-4 flex items-center">
                        <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        Actions rapides
                    </h3>
                    <div class="space-y-2">
                        <a href="{{ path('admin_album_index') }}" class="flex items-center text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 p-2.5 rounded-xl transition-all duration-200 group">
                            <svg class="w-4 h-4 mr-3 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                            </svg>
                            Voir tous les albums
                        </a>
                        <a href="{{ path('admin_photo_new') }}" class="flex items-center text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 p-2.5 rounded-xl transition-all duration-200 group">
                            <svg class="w-4 h-4 mr-3 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            Créer une photo seule
                        </a>
                    </div>
                </div>
            </div>

            <!-- Formulaire principal amélioré -->
            <div class="xl:w-3/4">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    {{ form_start(form, {'attr': {'class': 'divide-y divide-gray-100', 'novalidate': 'novalidate'}}) }}
                    
                    <!-- Section Informations -->
                    <div class="p-6 md:p-8">
                        <div class="flex items-center mb-6">
                            <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-xl flex items-center justify-center shadow-sm">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-gray-900">Informations de base</h3>
                                <p class="text-sm text-gray-500">Définissez le titre et la description de votre album</p>
                            </div>
                        </div>

                        <div class="space-y-6">
                            <!-- Titre avec compteur amélioré -->
                            <div>
                                {{ form_label(form.title, 'Titre de l\'album *', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1.5'}}) }}
                                <div class="relative">
                                    {{ form_widget(form.title, {'attr': {
                                        'class': 'w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-200',
                                        'placeholder': 'Ex: Vacances à la montagne 2024',
                                        'maxlength': 255,
                                        'data-counter': 'titleCounter'
                                    }}) }}
                                    <div class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400 bg-white px-1">
                                        <span id="titleCounter">0</span>/255
                                    </div>
                                </div>
                                {{ form_errors(form.title, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                                <p class="mt-1.5 text-xs text-gray-400">Un titre percutant attire plus de visiteurs</p>
                            </div>

                            <!-- Description avec compteur -->
                            <div>
                                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1.5'}}) }}
                                {{ form_widget(form.description, {'attr': {
                                    'class': 'w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-200 resize-none',
                                    'rows': 4,
                                    'placeholder': 'Racontez l\'histoire de cet album...',
                                    'maxlength': 1000,
                                    'data-counter': 'descCounter'
                                }}) }}
                                <div class="flex justify-between items-center mt-1.5">
                                    {{ form_errors(form.description, {'attr': {'class': 'text-red-500 text-xs'}}) }}
                                    <span class="text-xs text-gray-400"><span id="descCounter">0</span>/1000 caractères</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section Paramètres -->
                    <div class="p-6 md:p-8">
                        <div class="flex items-center mb-6">
                            <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl flex items-center justify-center shadow-sm">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-gray-900">Paramètres</h3>
                                <p class="text-sm text-gray-500">Configurez la date et la visibilité</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Date stylisée -->
                            <div>
                                {{ form_label(form.eventDate, 'Date de l\'événement', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1.5'}}) }}
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    {{ form_widget(form.eventDate, {'attr': {
                                        'class': 'w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all duration-200'
                                    }}) }}
                                </div>
                                {{ form_errors(form.eventDate, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                                <p class="mt-1.5 text-xs text-gray-400">Date à laquelle les photos ont été prises</p>
                            </div>

                            <!-- Visibilité avec toggle switch moderne -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Visibilité</label>
                                <div class="bg-gray-50/50 rounded-xl p-4 border border-gray-100">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-3">
                                            {{ form_widget(form.isPublic, {'attr': {
                                                'class': 'hidden toggle-checkbox'
                                            }}) }}
                                            <label for="{{ form.isPublic.vars.id }}" class="relative inline-flex items-center cursor-pointer">
                                                <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-blue-600 transition-colors duration-200 toggle-bg"></div>
                                                <div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform duration-200 toggle-circle"></div>
                                            </label>
                                            <span class="text-sm font-medium text-gray-700 toggle-label">{{ form.isPublic.vars.checked ? 'Public' : 'Privé' }}</span>
                                        </div>
                                        <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                                        </svg>
                                    </div>
                                    <div class="mt-3 p-2.5 bg-blue-50/50 rounded-lg border border-blue-100/50">
                                        <p class="text-xs text-blue-700 flex items-center">
                                            <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                                            </svg>
                                            <span id="visibilityMessage">{{ form.isPublic.vars.checked ? 'L\'album sera visible par tous les visiteurs' : 'L\'album ne sera visible que par les administrateurs' }}</span>
                                        </p>
                                    </div>
                                </div>
                                {{ form_errors(form.isPublic) }}
                            </div>
                        </div>
                    </div>

                    <!-- Section Couverture améliorée -->
                    <div class="p-6 md:p-8">
                        <div class="flex items-center mb-6">
                            <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center shadow-sm">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div class="ml-4">
                                <h3 class="text-lg font-bold text-gray-900">Photo de couverture</h3>
                                <p class="text-sm text-gray-500">Choisissez une image représentative (optionnel)</p>
                            </div>
                        </div>

                        <div>
                            {{ form_label(form.coverImageFile, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                            
                            <!-- Dropzone moderne -->
                            <div id="dropZone" class="relative mt-1 border-2 border-dashed border-gray-200 rounded-xl p-8 text-center hover:border-purple-400 hover:bg-purple-50/20 transition-all duration-200 cursor-pointer group">
                                <input type="file" id="{{ form.coverImageFile.vars.id }}" name="{{ form.coverImageFile.vars.full_name }}" class="hidden" accept="image/jpeg,image/png,image/webp">
                                <div class="text-center">
                                    <div class="mx-auto h-14 w-14 rounded-full bg-purple-100 flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                                        <svg class="h-7 w-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                                        </svg>
                                    </div>
                                    <div class="mt-4">
                                        <p class="text-sm font-medium text-gray-700">Glissez-déposez votre image ici</p>
                                        <p class="text-xs text-gray-400 mt-1">ou <span class="text-purple-600 font-medium">parcourez vos fichiers</span></p>
                                        <p class="text-xs text-gray-400 mt-2">PNG, JPG, WebP jusqu'à 5MB</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Aperçu amélioré -->
                            <div id="coverPreview" class="mt-6 hidden">
                                <div class="flex items-center justify-between mb-3">
                                    <p class="text-sm font-medium text-gray-700">Aperçu de la couverture</p>
                                    <button type="button" id="removePreview" class="text-xs text-red-500 hover:text-red-700 flex items-center gap-1">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                        Supprimer
                                    </button>
                                </div>
                                <div class="relative inline-block rounded-xl overflow-hidden shadow-md border border-gray-200">
                                    <img id="coverPreviewImage" class="max-h-56 w-auto object-cover" src="" alt="Aperçu de la couverture">
                                    <div class="absolute inset-0 bg-black/0 hover:bg-black/10 transition-colors"></div>
                                </div>
                            </div>
                            {{ form_errors(form.coverImageFile, {'attr': {'class': 'text-red-500 text-xs mt-2'}}) }}
                        </div>
                    </div>

                    <!-- Actions avec loading state -->
                    <div class="p-6 md:p-8 bg-gray-50/30">
                        <div class="flex flex-col-reverse sm:flex-row justify-between items-center gap-4">
                            <a href="{{ path('admin_album_index') }}" class="w-full sm:w-auto px-6 py-2.5 border border-gray-200 rounded-xl text-gray-700 hover:bg-gray-50 hover:border-gray-300 text-center font-medium transition-all duration-200">
                                Annuler
                            </a>
                            <div class="flex space-x-4 w-full sm:w-auto">
                                <button type="button" id="resetFormBtn" class="px-6 py-2.5 border border-gray-200 rounded-xl text-gray-600 hover:bg-gray-50 font-medium transition-all duration-200">
                                    Réinitialiser
                                </button>
                                <button type="submit" id="submitBtn" class="relative px-6 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-xl font-medium shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 disabled:opacity-70 disabled:cursor-not-allowed">
                                    <span class="flex items-center">
                                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                        Créer l'album
                                    </span>
                                    <span id="submitSpinner" class="absolute inset-0 flex items-center justify-center bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl hidden">
                                        <svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                        </svg>
                                    </span>
                                </button>
                            </div>
                        </div>
                    </div>
                    {{ form_end(form) }}
                </div>

                <!-- Footer info avec design amélioré -->
                <div class="mt-6 bg-gradient-to-r from-blue-50/80 to-transparent rounded-xl p-5 border border-blue-100">
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        <div class="ml-4">
                            <h4 class="font-semibold text-gray-800 text-sm">Après la création</h4>
                            <p class="text-xs text-gray-600 mt-1">Vous pourrez ajouter des photos, modifier la couverture et ajuster les paramètres à tout moment depuis l'interface d'administration.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ==================== COMPTEURS DE CARACTÈRES ====================
    const titleInput = document.querySelector('#{{ form.title.vars.id }}');
    const titleCounter = document.getElementById('titleCounter');
    const descInput = document.querySelector('#{{ form.description.vars.id }}');
    const descCounter = document.getElementById('descCounter');
    
    function updateCounter(input, counter, max) {
        if (input && counter) {
            const length = input.value.length;
            counter.textContent = length;
            if (length > max * 0.9) {
                counter.classList.add('text-orange-500');
            } else {
                counter.classList.remove('text-orange-500');
            }
        }
    }
    
    if (titleInput && titleCounter) {
        updateCounter(titleInput, titleCounter, 255);
        titleInput.addEventListener('input', () => updateCounter(titleInput, titleCounter, 255));
    }
    if (descInput && descCounter) {
        updateCounter(descInput, descCounter, 1000);
        descInput.addEventListener('input', () => updateCounter(descInput, descCounter, 1000));
    }
    
    // ==================== TOGGLE SWITCH POUR VISIBILITÉ ====================
    const toggleCheckbox = document.querySelector('.toggle-checkbox');
    const toggleBg = document.querySelector('.toggle-bg');
    const toggleCircle = document.querySelector('.toggle-circle');
    const toggleLabel = document.querySelector('.toggle-label');
    const visibilityMessageSpan = document.getElementById('visibilityMessage');
    
    function updateToggle() {
        if (toggleCheckbox.checked) {
            toggleBg.classList.remove('bg-gray-300');
            toggleBg.classList.add('bg-blue-600');
            toggleCircle.style.transform = 'translateX(1.25rem)';
            if (toggleLabel) toggleLabel.textContent = 'Public';
            if (visibilityMessageSpan) visibilityMessageSpan.textContent = 'L\'album sera visible par tous les visiteurs';
        } else {
            toggleBg.classList.remove('bg-blue-600');
            toggleBg.classList.add('bg-gray-300');
            toggleCircle.style.transform = 'translateX(0)';
            if (toggleLabel) toggleLabel.textContent = 'Privé';
            if (visibilityMessageSpan) visibilityMessageSpan.textContent = 'L\'album ne sera visible que par les administrateurs';
        }
    }
    
    if (toggleCheckbox) {
        // Initialiser l'état
        updateToggle();
        toggleCheckbox.addEventListener('change', updateToggle);
        // Synchroniser avec le checkbox Symfony original (caché)
        const originalCheckbox = document.querySelector('#{{ form.isPublic.vars.id }}');
        if (originalCheckbox) {
            toggleCheckbox.checked = originalCheckbox.checked;
            updateToggle();
            toggleCheckbox.addEventListener('change', function() {
                originalCheckbox.checked = this.checked;
                originalCheckbox.dispatchEvent(new Event('change'));
            });
            originalCheckbox.addEventListener('change', function() {
                if (toggleCheckbox.checked !== this.checked) {
                    toggleCheckbox.checked = this.checked;
                    updateToggle();
                }
            });
        }
    }
    
    // ==================== UPLOAD D'IMAGE AVEC APERÇU ====================
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.querySelector('#{{ form.coverImageFile.vars.id }}');
    const previewDiv = document.getElementById('coverPreview');
    const previewImg = document.getElementById('coverPreviewImage');
    const removeBtn = document.getElementById('removePreview');
    
    function handleFileSelect(file) {
        if (file && file.type.match('image.*')) {
            // Vérifier la taille (5MB max)
            if (file.size > 5 * 1024 * 1024) {
                alert('Le fichier est trop volumineux. Taille maximum : 5MB');
                fileInput.value = '';
                return;
            }
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                previewDiv.classList.remove('hidden');
                if (dropZone) dropZone.classList.add('hidden');
            };
            reader.readAsDataURL(file);
        } else {
            alert('Veuillez sélectionner une image valide (PNG, JPG, WebP)');
            fileInput.value = '';
        }
    }
    
    if (dropZone && fileInput) {
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                handleFileSelect(this.files[0]);
            }
        });
        
        // Drag & drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, preventDefaults, false);
        });
        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('border-purple-500', 'bg-purple-50/30'));
        });
        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('border-purple-500', 'bg-purple-50/30'));
        });
        dropZone.addEventListener('drop', function(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            if (files && files[0]) {
                fileInput.files = files;
                handleFileSelect(files[0]);
            }
        });
    }
    
    if (removeBtn) {
        removeBtn.addEventListener('click', function() {
            previewDiv.classList.add('hidden');
            if (dropZone) dropZone.classList.remove('hidden');
            fileInput.value = '';
            previewImg.src = '';
        });
    }
    
    // ==================== RÉINITIALISATION DU FORMULAIRE ====================
    const resetBtn = document.getElementById('resetFormBtn');
    const formElement = document.querySelector('form');
    
    function resetForm() {
        if (formElement) {
            formElement.reset();
            // Réinitialiser les compteurs
            if (titleInput && titleCounter) updateCounter(titleInput, titleCounter, 255);
            if (descInput && descCounter) updateCounter(descInput, descCounter, 1000);
            // Réinitialiser le toggle de visibilité
            if (toggleCheckbox) {
                const originalCheckbox = document.querySelector('#{{ form.isPublic.vars.id }}');
                if (originalCheckbox) {
                    toggleCheckbox.checked = originalCheckbox.checked;
                    updateToggle();
                }
            }
            // Réinitialiser l'aperçu de l'image
            if (previewDiv && dropZone) {
                previewDiv.classList.add('hidden');
                dropZone.classList.remove('hidden');
                fileInput.value = '';
                previewImg.src = '';
            }
        }
    }
    
    if (resetBtn) {
        resetBtn.addEventListener('click', (e) => {
            if (confirm('Voulez-vous vraiment réinitialiser tous les champs ?')) {
                resetForm();
            }
        });
    }
    
    // ==================== LOADING STATE AU SUBMIT ====================
    const submitBtn = document.getElementById('submitBtn');
    const submitSpinner = document.getElementById('submitSpinner');
    const submitBtnText = submitBtn?.querySelector('span:not(#submitSpinner)');
    
    if (submitBtn && formElement) {
        formElement.addEventListener('submit', function() {
            submitBtn.disabled = true;
            if (submitSpinner) submitSpinner.classList.remove('hidden');
            if (submitBtnText) submitBtnText.classList.add('opacity-0');
        });
    }
    
    // ==================== VALIDATION FRONT SIMPLE ====================
    if (titleInput && formElement) {
        formElement.addEventListener('submit', function(e) {
            if (!titleInput.value.trim()) {
                e.preventDefault();
                alert('Le titre de l\'album est requis.');
                titleInput.focus();
                return false;
            }
        });
    }
});
</script>

<style>
/* Styles personnalisés pour le toggle switch */
.toggle-checkbox:checked + label .toggle-bg {
    background-color: #2563eb;
}
.toggle-checkbox:checked + label .toggle-circle {
    transform: translateX(1.25rem);
}
</style>
{% endblock %}
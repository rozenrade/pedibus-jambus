{% extends 'base.html.twig' %}

{% block title %}
    {{ album.title }}
    - Administration
{% endblock %}

{% block body %}
    <div
    class="container mx-auto px-4 py-8">
    <!-- En-tête -->
    <div class="relative overflow-hidden rounded-3xl bg-white/80 backdrop-blur shadow-xl border border-white/20 p-8 mb-10">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">

            <div>
                <div class="flex items-center gap-3 mb-3">
                    <span class="px-3 py-1 rounded-full text-sm font-medium
                        {{ album.isPublic
                        ? 'bg-emerald-100 text-emerald-700'
                        : 'bg-gray-100 text-gray-700'
                        }}">
                        {{ album.isPublic ? 'Public' : 'Privé' }}
                    </span>

                    <span class="text-sm text-gray-500">
                        {{ album.photos|length }} photos
                    </span>
                </div>

                <h1 class="text-4xl font-black tracking-tight text-gray-900">
                    {{ album.title }}
                </h1>

                <p class="text-gray-500 mt-2">
                    {{ album.eventDate|date('d/m/Y') }}
                </p>

                {% if album.description %}
                    <p class="mt-5 text-gray-700 leading-relaxed max-w-3xl">
                        {{ album.description }}
                    </p>
                {% endif %}
            </div>

            <div class="flex gap-3">
                <a href="{{ path('admin_album_edit', {'id': album.id}) }}"
                    class="px-5 py-3 rounded-2xl bg-white border border-gray-200 hover:border-gray-300 shadow-sm">
                    Modifier
                </a>

                <a href="{{ path('admin_photo_new_to_album', {'albumId': album.id}) }}"
                    class="px-5 py-3 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-500/20">
                    + Ajouter
                </a>
            </div>
        </div>
    </div>


    <!-- Couverture -->
    {% if album.coverImage %}
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-gray-900 mb-4">Couverture</h2>
            <a href="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" target="_blank" rel="noopener noreferrer">
                <img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" alt="{{ album.title }}" class="w-full max-w-md rounded-lg shadow-sm">
            </a>
        </div>
    {% endif %}

    <!-- Photos -->
    <div>

        {% if album.photos|length == 0 %}
            <div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-200">
                <div class="text-gray-400 mb-4">
                    <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-medium text-gray-900 mb-2">Aucune photo</h3>
                <p class="text-gray-500 mb-6">Commencez par ajouter des photos à cet album</p>
                <div class="flex justify-center space-x-4">
                    <a href="{{ path('admin_photo_new_to_album', {'albumId': album.id}) }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
                        + Ajouter une photo
                    </a>
                    <a href="{{ path('admin_photo_multiple_to_album', {'albumId': album.id}) }}" class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-800 px-4 py-2 rounded-lg font-medium">
                        Ajouter plusieurs photos
                    </a>
                </div>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-7xl mx-auto">
                {% for photo in album.photos %}
                    <div class="group bg-white rounded-xl shadow-sm hover:shadow-md border border-gray-200/80 overflow-hidden transition-shadow duration-300">
                        <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                            <a href="{{ asset('uploads/photos/' ~ photo.imageName) }}" target="_blank" rel="noopener noreferrer" class="block w-full h-full">
                                <img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="Photo"
                                    class="w-full h-full object-cover">
                                </a>
                            </div>

                            <div class="p-3 flex items-center justify-between">
                                <span class="text-xs text-gray-500 font-medium">
                                    {{ photo.updatedAt|date('d/m/Y') }}
                                </span>
                                <div class="flex items-center gap-x-1.5">
                                    <a href="{{ path('admin_photo_edit', {'id': photo.id}) }}"
                                        class="text-xs font-medium px-2 py-1 rounded-md bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors">
                                        Modifier
                                    </a>
                                    <span class="text-gray-300 text-xs">•</span>
                                    <a href="{{ path('admin_photo_delete', {'id': photo.id}) }}"
                                        class="text-xs font-medium px-2 py-1 rounded-md bg-red-50 text-red-700 hover:bg-red-100 transition-colors">
                                        Supprimer
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

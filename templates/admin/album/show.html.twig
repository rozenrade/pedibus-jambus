{% extends 'base.html.twig' %}

{% block title %}
	{{ album.title }}
	- Administration
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-4 py-8">
		<!-- En-tête -->
		<div class="mb-8">
			<div class="flex justify-between items-start">
				<div>
					<h1 class="text-3xl font-bold text-gray-900">{{ album.title }}</h1>
					<p class="text-gray-600 mt-2">
						{{ album.eventDate|date('d/m/Y') }}
						•
						{{ album.photos|length }}
						photo(s) •
						<span class="{{ album.isPublic ? 'text-green-600' : 'text-gray-600' }}">
							{{ album.isPublic ? 'Public' : 'Privé' }}
						</span>
					</p>
				</div>
				<div class="flex space-x-2">
					<a href="{{ path('admin_album_edit', {'id': album.id}) }}" class="bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-medium">
						Modifier
					</a>
					<a href="{{ path('admin_photo_new_to_album', {'albumId': album.id}) }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
						+ Ajouter des photos
					</a>
				</div>
			</div>

			{% if album.description %}
				<div class="mt-4 p-4 bg-gray-50 rounded-lg">
					<p class="text-gray-700">{{ album.description }}</p>
				</div>
			{% endif %}
		</div>

		<!-- Couverture -->
		{% if album.coverImage %}
			<div class="mb-8">
				<h2 class="text-xl font-semibold text-gray-900 mb-4">Couverture</h2>
				<a href="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" target="_blank" rel="noopener noreferrer">
					<img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" alt="{{ album.title }}" class="w-full max-w-md rounded-lg shadow-sm">
				</a>
			</div>
		{% endif %}

		<!-- Photos -->
		<div>
			<div class="flex justify-between items-center mb-4">
				<h2 class="text-xl font-semibold text-gray-900">Photos ({{ album.photos|length }})</h2>
				{% if album.photos|length > 0 %}
					<a href="{{ path('admin_photo_multiple_to_album', {'albumId': album.id}) }}" class="text-blue-600 hover:text-blue-800 font-medium">
						+ Ajouter plus de photos
					</a>
				{% endif %}
			</div>

			{% if album.photos|length == 0 %}
				<div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-200">
					<div class="text-gray-400 mb-4">
						<svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
						</svg>
					</div>
					<h3 class="text-lg font-medium text-gray-900 mb-2">Aucune photo</h3>
					<p class="text-gray-500 mb-6">Commencez par ajouter des photos à cet album</p>
					<div class="flex justify-center space-x-4">
						<a href="{{ path('admin_photo_new_to_album', {'albumId': album.id}) }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
							+ Ajouter une photo
						</a>
						<a href="{{ path('admin_photo_multiple_to_album', {'albumId': album.id}) }}" class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-800 px-4 py-2 rounded-lg font-medium">
							Ajouter plusieurs photos
						</a>
					</div>
				</div>
			{% else %}
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
					{% for photo in album.photos %}
						<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
							{% if photo.imageName %}
								<div class="aspect-square overflow-hidden bg-gray-100">
									<a href="{{ asset('uploads/photos/' ~ photo.imageName) }}" target="_blank" ref="noopener noreferrer">
										<img src="{{ asset('uploads/photos/' ~ photo.imageName) }}" alt="Photo" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
									</a>
								</div>
							{% endif %}
							<div class="p-3">
								<div class="flex justify-between items-center">
									<span class="text-xs text-gray-500">
										{{ photo.updatedAt|date('d/m/Y') }}
									</span>
									<div class="flex space-x-1">
										<a href="{{ path('admin_photo_edit', {'id': photo.id}) }}" class="text-blue-600 hover:text-blue-800 text-sm">
											Modifier
										</a>
										<span class="text-gray-300">•</span>
										<a href="{{ path('admin_photo_delete', {'id': photo.id}) }}" class="text-red-600 hover:text-red-800 text-sm">
											Supprimer
										</a>
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}

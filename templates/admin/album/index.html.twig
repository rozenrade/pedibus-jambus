{% extends 'base.html.twig' %}

{% block title %}Albums - Administration
{% endblock %}

{% block body %}
	<div class="container mx-auto px-4 py-8">
		<div class="flex justify-between items-center mb-8">
			<div>
				<h1 class="text-3xl font-bold text-gray-900">Albums</h1>
				<p class="text-gray-600 mt-2">Gérez vos albums photos</p>
			</div>
			<a href="{{ path('admin_album_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium">
				+ Nouvel album
			</a>
		</div>

		{% for message in app.flashes('success') %}
			<div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
				{{ message }}
			</div>
		{% endfor %}

		{% if albums|length == 0 %}
			<div class="text-center py-12">
				<div class="text-gray-400 mb-4">
					<svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
					</svg>
				</div>
				<h3 class="text-lg font-medium text-gray-900 mb-2">Aucun album</h3>
				<p class="text-gray-500 mb-4">Commencez par créer votre premier album</p>
				<a href="{{ path('admin_album_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium inline-block">
					Créer un album
				</a>
			</div>
		{% else %}
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{% for album in albums %}
					<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
						{% if album.coverImage %}
							<div class="h-48 overflow-hidden">
								<a href="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" target="_blank" rel="noopener noreferrer">
									<img src="{{ asset('uploads/albums/covers/' ~ album.coverImage) }}" alt="{{ album.title }}" class="w-full h-full object-cover">
								</a>
							</div>
						{% else %}
							<div class="h-48 bg-gray-100 flex items-center justify-center">
								<svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
									<path stroke-linecap="round" stroke-linecap="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
								</svg>
							</div>
						{% endif %}

						<div class="p-4">
							<div class="flex justify-between items-start">
								<div>
									<h3 class="font-semibold text-lg text-gray-900">{{ album.title }}</h3>
									<p class="text-sm text-gray-500 mt-1">
										{{ album.eventDate|date('d/m/Y') }}
									</p>
								</div>
								<span class="px-2 py-1 text-xs font-medium rounded-full {{ album.isPublic ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' }}">
									{{ album.isPublic ? 'Public' : 'Privé' }}
								</span>
							</div>

							{% if album.description %}
								<p class="text-gray-600 text-sm mt-3 line-clamp-2">
									{{ album.description }}
								</p>
							{% endif %}

							<div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
								<div class="text-sm text-gray-500">
									{{ album.photos|length }}
									photo(s)
								</div>
								<div class="flex space-x-2">
									<a href="{{ path('admin_album_show', {'id': album.id}) }}" class="text-blue-600 hover:text-blue-800 text-sm font-medium">
										Voir
									</a>
									<a href="{{ path('admin_album_edit', {'id': album.id}) }}" class="text-gray-600 hover:text-gray-800 text-sm font-medium">
										Modifier
									</a>
								</div>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</div>
{% endblock %}
